---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Terms of Service | Chinook Driving School Calgary"
  description="Read the terms of service for Chinook Driving School Calgary."
>
  <section class="bg-n-50">
    <div class="container mx-auto flex w-full max-w-4xl flex-col gap-6 px-6 py-16 lg:px-0 lg:py-24">
      <h1 class="text-n-800 text-3xl font-bold leading-tight lg:text-5xl">Terms of Service</h1>
      <p class="text-n-600 text-base leading-7">
        By using this website or enrolling in a course, you agree to follow the policies,
        scheduling requirements, and payment terms communicated by Chinook Driving School Calgary.
      </p>
      <p class="text-n-600 text-base leading-7">
        Course availability, instructor scheduling, vehicle access, and road test support may vary
        depending on the selected package and current availability.
      </p>
      <p class="text-n-600 text-base leading-7">
        Please contact our team before booking if you need clarification on package inclusions,
        cancellations, or test-day support.
      </p>
    </div>
  </section>
</Layout>
