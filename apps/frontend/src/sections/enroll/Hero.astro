---
// COMPONENTS //
import { Image } from "astro:assets";

// IMAGES //
import heroIllustration from "@/assets/enroll-hero.png";

// DATA //
import { enrollHeroData } from "@/data/enroll-hero-data";
---

<section class="bg-n-100 overflow-hidden">
  <div class="container mx-auto flex flex-col gap-9 px-6 pt-22 md:gap-10 md:px-2 lg:flex-row lg:justify-between lg:pt-24">
    <div class="flex flex-col gap-6 md:gap-7 lg:gap-8 lg:self-end lg:pb-32">
      <p class="text-3xl font-bold leading-tight text-n-900 md:text-5xl lg:text-6xl">
        {enrollHeroData.title}
      </p>
      <p class="text-sm font-medium leading-6 text-n-700 md:text-lg md:leading-7 lg:text-xl">
        {enrollHeroData.description}
      </p>
    </div>

    <div class="flex h-[233px] w-full overflow-hidden opacity-50 md:h-[550px] lg:w-auto">
      <Image
        src={heroIllustration}
        alt="Instructor and learner shaking hands"
        class="h-[156%] w-full object-cover object-top grayscale"
      />
    </div>
  </div>
</section>
