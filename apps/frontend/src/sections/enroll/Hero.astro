---
// COMPONENTS //
import { Image } from "astro:assets";

// IMAGES //
import heroImage from "@/assets/enroll-hero.png";
---

<section class="bg-n-100">
  <div class="container mx-auto max-w-screen-2xl px-6 pt-24 pb-14 md:pt-28 md:pb-16 lg:px-5 lg:pt-32 lg:pb-32">
    <div class="flex flex-col gap-10 lg:flex-row lg:items-end lg:justify-between lg:gap-12">
      <div class="max-w-2xl space-y-6 lg:pb-32">
        <p class="text-n-900 text-3xl leading-tight font-bold md:text-5xl lg:text-6xl">
          Start Your Driving Journey with Chinook
        </p>
        <p class="text-n-700 text-sm leading-5 font-medium md:text-lg md:leading-7 lg:text-xl lg:leading-7">
          Learn from certified instructors and get road-ready with expert guidance every step of the way.
        </p>
      </div>

      <div class="flex w-full items-center justify-center">
        <div class="w-full max-w-2xl lg:max-w-3xl">
          <Image
            src={heroImage}
            alt="Instructor and learner shaking hands"
            width={700}
            height={500}
            class="h-auto w-full object-contain grayscale opacity-50"
          />
        </div>
      </div>
    </div>
  </div>
</section>
