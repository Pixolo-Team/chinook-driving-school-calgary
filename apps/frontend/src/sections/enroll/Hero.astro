---
// COMPONENTS //
import HeroCard from "@/components/HeroCard.astro";

// DATA //
import { enrollHeroData } from "@/data/enroll-hero-data";
import { getSiteContentData, isNonEmptyString } from "@/data/site-content-api";

const siteContentData = await getSiteContentData();
const enrollHeroApiData = siteContentData?.enroll_hero;

const heroContent = {
  title: isNonEmptyString(enrollHeroApiData?.title) ? enrollHeroApiData.title : enrollHeroData.title,
  description: isNonEmptyString(enrollHeroApiData?.description)
    ? enrollHeroApiData.description
    : enrollHeroData.description,
};

---

<section class="bg-n-100 overflow-hidden">
  <HeroCard
    title={heroContent.title}
    description={heroContent.description}
    illustration={enrollHeroData.illustration}
    illustrationAlt={enrollHeroData.illustrationAlt}
  />
</section>
