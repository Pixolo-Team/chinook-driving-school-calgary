---
// DATA
import { faqSectionData as faqs } from "@/data/faqSectionData";
import { getSiteContentData, isNonEmptyString } from "@/data/site-content-api";

// COMPONENTS
import FaqItem from "@/components/FaqItem.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const siteContentData = await getSiteContentData();
const faqApiData = siteContentData?.faq;

const faqHeader = {
  eyebrow: "Got Questions ?",
  heading: isNonEmptyString(faqApiData?.title) ? faqApiData.title : "Frequently Asked Questions",
};

const faqDescription = isNonEmptyString(faqApiData?.description) ? faqApiData.description : "";
const faqCardsFromApi =
  faqApiData?.faq_cards
    ?.filter((faqCard) => isNonEmptyString(faqCard.question) && isNonEmptyString(faqCard.answer))
    .map((faqCard) => ({
      question: faqCard.question,
      answer: faqCard.answer,
    })) ?? [];

const faqCards = faqCardsFromApi.length > 0 ? faqCardsFromApi : faqs;
---

<section class="bg-n-100">
  <div class="container mx-auto flex w-full flex-col items-center gap-16 overflow-hidden px-5 py-24 lg:py-36 xl:px-0">

    <!-- Heading & Description -->
    <SectionHeader
      eyebrow={faqHeader.eyebrow}
      heading={faqHeader.heading}
      description={faqDescription}
    />

    <!-- FAQ Cards -->
    <div class="mx-auto flex w-full max-w-6xl flex-col gap-5">
      {faqCards.map((faqItem) => (
        <FaqItem question={faqItem.question} answer={faqItem.answer} />
      ))}
    </div>

  </div>
</section>

<script>
  import { initializeFaqSection } from "@/scripts/faq";

  initializeFaqSection();
</script>
