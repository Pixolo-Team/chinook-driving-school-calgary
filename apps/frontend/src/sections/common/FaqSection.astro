---
// DATA
import { getFaqViewModel } from "@/data/site-content-mappers";

// COMPONENTS
import FaqItem from "@/components/FaqItem.astro";
import SectionHeader from "@/components/SectionHeader.astro";

const faqViewModel = await getFaqViewModel();
const faqHeader = {
  eyebrow: faqViewModel.eyebrow,
  heading: faqViewModel.heading,
};
const faqDescription = faqViewModel.description;
const faqCards = faqViewModel.cards;
---

<section class="bg-n-100">
  <div class="container mx-auto flex w-full flex-col items-center gap-16 overflow-hidden px-5 py-24 lg:py-36 xl:px-0">

    <!-- Heading & Description -->
    <SectionHeader
      eyebrow={faqHeader.eyebrow}
      heading={faqHeader.heading}
      description={faqDescription}
    />

    <!-- FAQ Cards -->
    <div class="mx-auto flex w-full max-w-6xl flex-col gap-5">
      {faqCards.map((faqItem) => (
        <FaqItem question={faqItem.question} answer={faqItem.answer} />
      ))}
    </div>

  </div>
</section>

<script>
  import { initializeFaqSection } from "@/scripts/faq";

  initializeFaqSection();
</script>
