---
// DATA
import { faqSectionData as faqs } from "@/data/faqSectionData";
import { fetchContentSection } from "@/data/site-content-api";

// COMPONENTS
import FaqItem from "@/components/FaqItem.astro";

type FaqApiSection = {
  title?: string;
  description?: string;
  faq_cards?: Array<{
    question?: string;
    answer?: string;
  }>;
};

const apiFaqSection = await fetchContentSection<FaqApiSection>("faq");

const faqHeader = {
  eyebrow: "Got Questions ?",
  title:
    typeof apiFaqSection?.title === "string" && apiFaqSection.title.trim() !== ""
      ? apiFaqSection.title
      : "Frequently Asked Questions",
};

const faqDescription =
  typeof apiFaqSection?.description === "string" && apiFaqSection.description.trim() !== ""
    ? apiFaqSection.description
    : "";

const faqCards =
  Array.isArray(apiFaqSection?.faq_cards) && apiFaqSection.faq_cards.length > 0
    ? apiFaqSection.faq_cards.map((faq, index) => ({
        question:
          typeof faq.question === "string" && faq.question.trim() !== ""
            ? faq.question
            : faqs[index]?.question ?? "",
        answer:
          typeof faq.answer === "string" && faq.answer.trim() !== ""
            ? faq.answer
            : faqs[index]?.answer ?? "",
      }))
    : faqs;
---

<section class="bg-n-100">
  <div class="container mx-auto flex w-full flex-col items-center gap-16 overflow-hidden px-5 py-24 lg:py-36 xl:px-0">

    <!-- Heading & Description -->
    <div class="flex flex-col items-center gap-2.5">
      <p class="text-sm font-bold uppercase tracking-[0.6px] text-blue-600">
        {faqHeader.eyebrow}
      </p>
      <p
        class="text-center text-3xl font-bold leading-tight text-n-800 md:text-5xl"
      >
        {faqHeader.title}
      </p>
      {faqDescription && (
        <p class="text-center text-base text-n-600">
          {faqDescription}
        </p>
      )}
    </div>

    <!-- FAQ Cards -->
    <div class="mx-auto flex w-full max-w-6xl flex-col gap-5">
      {faqCards.map((faqItem) => (
        <FaqItem question={faqItem.question} answer={faqItem.answer} />
      ))}
    </div>

  </div>
</section>

<script>
  import { initializeFaqSection } from "@/scripts/faq";

  initializeFaqSection();
</script>
