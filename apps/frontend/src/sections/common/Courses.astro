---
// COMPONENTS //
import CourseCard from "@/components/CourseCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import Tabs from "@/components/ui/Tabs.astro";

// DATA //
import { courseSectionData } from "@/data/courses";

---

<section class="bg-n-50">
  <div
    class="container mx-auto flex w-full flex-col items-center gap-10 px-6 py-14 lg:gap-16 lg:px-28 lg:py-28"
  >
    <!-- Section Header -->
    <SectionHeader
      eyebrow={courseSectionData.eyebrow}
      heading={courseSectionData.heading}
      description={courseSectionData.description}
    />

    <!-- Courses Category Tabs -->
    <div class="flex w-full flex-col items-center gap-7 md:gap-8 md:px-20 lg:gap-12 xl:px-0">
      <div class="w-full max-w-3xl">
        <Tabs items={courseSectionData.tabs} activeIndex={0} />
      </div>

      <!--  -->
      <div class="w-full max-w-3xl lg:max-w-none">
        <div class="grid w-full grid-cols-1 gap-5 xl:grid-cols-3">
          {courseSectionData.cards.map((card) => <CourseCard {...card} />)}
        </div>
      </div>
    </div>
  </div>
</section>
