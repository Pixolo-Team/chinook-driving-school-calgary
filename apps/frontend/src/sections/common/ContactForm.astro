---
// COMPONENTS //
import { Image } from "astro:assets";

// IMAGES //
import contactIllustration from "@/assets/contact-illustration.png";

type FormField = {
  label: string;
  name: string;
  type: "text" | "email" | "tel";
  placeholder: string;
  required?: boolean;
  minLength?: number;
  pattern?: string;
  title?: string;
};

const fieldRows: FormField[][] = [
  [
    {
      label: "Name",
      name: "name",
      type: "text",
      placeholder: "Enter your Name",
      required: true,
      minLength: 2,
      title: "Name must be at least 2 characters long.",
    },
  ],
  [
    {
      label: "Email Address",
      name: "email",
      type: "email",
      placeholder: "you@email.com",
      required: true,
    },
    {
      label: "Phone Number",
      name: "phone",
      type: "tel",
      placeholder: "+1 XXXX XXXX XX",
      required: true,
      pattern: "^\\+?[0-9\\s\\-\\(\\)]{7,15}$",
      title: "Please enter a valid phone number between 7 and 15 digits.",
    },
  ],
  [
    {
      label: "Reason",
      name: "reason",
      type: "text",
      placeholder: "Reason for Contact",
      required: false
    },
  ],
];
---

<section class="bg-n-50">
  <!-- Contact Form -->
  <div class="container mx-auto max-w-screen-2xl px-6 py-8 md:py-9 xl:px-44">
    <!-- Outer Box -->
    <div class="rounded-3xl bg-blue-50 p-3 md:p-6">
      <div class="grid gap-4 xl:grid-cols-12 xl:items-stretch xl:gap-6">
        <div class="xl:col-span-8">
          <div class="bg-n-50 h-full rounded-3xl p-6 md:p-8">
            <div class="h-full relative">
              <div id="form-container" class="flex h-full flex-col space-y-5 md:space-y-6 transition-opacity duration-300">
                <!-- Form Title -->
                <p class="text-n-900 text-xl leading-7 font-bold md:text-2xl">Reach out to us!</p>

                <form id="contact-form" method="post" action="" class="flex flex-1 flex-col space-y-4 md:space-y-6">
                  {
                    fieldRows.map((fieldRow) => (
                      <div
                        class:list={[
                          "grid gap-4",
                          fieldRow.length === 2 ? "md:grid-cols-2 md:gap-6" : "",
                        ]}
                      >
                        {/* Iterating through Form Input fields */}
                        {fieldRow.map((field) => (
                          <label class="block space-y-1">
                            <span class="text-n-950 block text-base leading-5 font-semibold">
                              {field.label} {field.required && <span class="text-red-500">*</span>}
                            </span>
                            <input
                              type={field.type}
                              name={field.name}
                              placeholder={field.placeholder}
                              required={field.required}
                              minlength={field.minLength}
                              pattern={field.pattern}
                              title={field.title}
                              class="bg-n-100 text-n-800 placeholder:text-n-400 w-full rounded-xl border border-transparent px-4 py-3 text-lg leading-6 transition-shadow duration-300 outline-none focus:ring-2 focus:ring-blue-500 md:py-4 invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500"
                            />
                          </label>
                        ))}
                      </div>
                    ))
                  }

                  <label class="block space-y-1">
                    <span class="text-n-950 block text-base leading-5 font-semibold">
                      Message <span class="text-red-500">*</span>
                    </span>

                    <!-- Message Section -->
                    <textarea
                      name="message"
                      required
                      placeholder="Tell us what's on your mind..."
                      class="bg-n-100 text-n-800 placeholder:text-n-400 min-h-44 w-full rounded-xl border border-transparent px-4 py-3 text-lg leading-6 transition-shadow duration-300 outline-none focus:ring-2 focus:ring-blue-500 md:py-4 invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-500"
                    ></textarea>
                  </label>

                  <!-- Send Message Button -->
                  <div class="mt-auto pt-2">
                    <button
                      type="submit"
                      class="animate-bouncy-hover text-n-50 w-full cursor-pointer rounded-full bg-blue-500 px-6 py-3 text-sm leading-6 font-bold transition-colors duration-300 hover:bg-blue-600 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:outline-none disabled:opacity-70 disabled:cursor-not-allowed"
                    >
                      Send Message
                    </button>
                  </div>
                </form>
              </div>

              <div id="success-message" class="hidden absolute inset-0 flex flex-col items-center justify-center text-center space-y-4 bg-n-50 rounded-3xl animate-fade-in z-10">
                <div class="size-20 rounded-full bg-green-100 flex items-center justify-center text-green-600 mb-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <h3 class="text-n-900 text-2xl font-bold md:text-3xl">Thank You!</h3>
                <p class="text-n-600 max-w-sm mx-auto text-lg">
                  Your message has been successfully sent. We'll get back to you within 24 hours.
                </p>
                <button id="reset-form-btn" type="button" class="mt-6 text-blue-500 font-semibold hover:text-blue-600 transition-colors cursor-pointer">
                  Send another message
                </button>
              </div>

            </div>
          </div>
        </div>

        <div class="xl:col-span-4">
          <!-- Contact Illustration Section -->
          <div
            class="bg-n-50 relative h-full overflow-hidden rounded-4xl px-4 py-4 md:px-7 md:py-6"
          >
            <div
              class="absolute top-12 -right-16 size-64 rounded-full bg-blue-100/20 md:top-1/2 md:right-auto md:-left-44 md:size-70 md:-translate-y-1/2 xl:top-44 xl:-right-48 xl:left-auto xl:size-96 xl:translate-y-0"
            >
            </div>

            <div
              class="relative z-10 flex h-full flex-col gap-10 md:flex-row md:items-stretch md:gap-8 xl:flex-col xl:gap-24"
            >
              <div class="mx-auto md:w-60 lg:w-72">
                <Image
                  src={contactIllustration}
                  alt="Instructor illustration"
                  width={472}
                  height={516}
                  class="h-auto w-full"
                />
              </div>

              <div class="flex flex-col gap-10 md:flex-1 md:justify-between xl:gap-24">
                <div class="space-y-3 md:max-w-[23rem] md:space-y-5 xl:max-w-none">
                  <p class="text-n-800 text-xl leading-tight font-semibold md:text-3xl">
                    We normally get back to you within <span class="font-bold">24 hours</span>.
                  </p>
                </div>

                <div class="space-y-3.5 md:space-y-6">
                  <div class="border-n-200 border-t"></div>
                  <p
                    class="text-n-600 max-w-[23rem] text-sm leading-tight md:text-base xl:max-w-none"
                  >
                    Our team is here to help you every step of the way.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const formContainer = document.getElementById("form-container");
  const successMessage = document.getElementById("success-message");
  const resetBtn = document.getElementById("reset-form-btn");

  if (form && formContainer && successMessage) {
    form.addEventListener("submit", (e) => {
      e.preventDefault(); 
      
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.innerText;
      
      submitBtn.innerText = "Sending...";
      submitBtn.disabled = true;

      setTimeout(() => {
        formContainer.classList.add("opacity-0", "pointer-events-none", "hidden");
        successMessage.classList.remove("hidden");
        
        submitBtn.innerText = originalText;
        submitBtn.disabled = false;
        form.reset();
      }, 600); 
    });
  }

  if (resetBtn && formContainer && successMessage) {
    resetBtn.addEventListener("click", () => {
      successMessage.classList.add("hidden");
      formContainer.classList.remove("hidden", "opacity-0", "pointer-events-none");
    });
  }
</script>