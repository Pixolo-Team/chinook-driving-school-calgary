---
// COMPONENTS //
import { Image } from "astro:assets";
import SectionHeader from "@/components/SectionHeader.astro";

// DATA //
import { processSectionData } from "@/data/process-section-data";

---

<section class="bg-n-100">
  <div class="container mx-auto flex w-full max-w-screen-2xl flex-col items-center gap-10 px-6 py-20 md:gap-12 md:px-6 md:py-28 lg:px-12 xl:gap-14 xl:px-32">
    
    <!-- Section Header -->
    <SectionHeader
      eyebrow={processSectionData.eyebrow}
      heading={processSectionData.heading}
      description={processSectionData.description}
    />

    <div class="grid w-full grid-cols-1 gap-3 md:grid-cols-2 md:gap-5 xl:grid-cols-3 xl:gap-6">
      {processSectionData.steps.map((step) => (
        <div class="relative flex h-full flex-col overflow-hidden rounded-4xl border border-n-300 bg-n-50 p-8 md:p-9 xl:p-10">
            
            
            <Image
            src={step.ellipse}
            alt=""
            width={353}
            height={353}
            class="pointer-events-none absolute -left-[271px] top-[102px] size-[353px]"
            aria-hidden="true"
          />
          <div class="relative flex flex-col gap-6">
            <p class="text-4xl font-bold leading-none text-blue-500 xl:text-5xl">
              {step.number}
            </p>
            <div class="flex flex-col gap-3">
              <p class="text-lg font-bold leading-snug text-n-700 md:text-xl xl:text-2xl">
                {step.titleLines.map((line) => (
                  <span class="block">{line}</span>
                ))}
              </p>
              <p class="text-sm leading-relaxed text-n-600 xl:text-base">
                {step.description}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
