---
// COMPONENTS //
import HeroCard from "@/components/HeroCard.astro";

// DATA //
import { coursesHeroSectionData } from "@/data/courses";
import { getSiteContentData, isNonEmptyString } from "@/data/site-content-api";

const siteContentData = await getSiteContentData();
const coursesHeroApiData = siteContentData?.courses_hero;

const heroContent = {
  title: isNonEmptyString(coursesHeroApiData?.title)
    ? coursesHeroApiData.title
    : coursesHeroSectionData.title,
  description: isNonEmptyString(coursesHeroApiData?.description)
    ? coursesHeroApiData.description
    : coursesHeroSectionData.description,
};

---

<section class="bg-n-100 overflow-hidden">
  <HeroCard
    title={heroContent.title}
    description={heroContent.description}
    illustration={coursesHeroSectionData.illustration}
    illustrationAlt={coursesHeroSectionData.illustrationAlt}
  />
</section>
