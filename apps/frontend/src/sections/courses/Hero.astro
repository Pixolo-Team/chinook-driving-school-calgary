---
// DATA //
import { coursesHeroSectionData } from "@/data/courses";

// COMPONENTS //
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

// IMAGES //
import logoSymbol from "@/../public/images/chinook-logo-symbol.svg";
import logoWordmark from "@/../public/images/chinook-logo-wordmark.svg";
import heroIllustration from "@/../public/images/courses-hero-illustration.png";
---

<section class="bg-n-100 overflow-hidden">
  <!-- Header -->
  <div class="w-full">
    <!-- Mobile + Tablet Header -->
    <div class="mx-auto flex w-full max-w-screen-2xl items-center justify-between px-6 py-4 lg:hidden">
      <div class="flex items-center gap-0.5">
        <Image
          src={logoSymbol}
          alt="Chinook Driving School Calgary"
          width={48}
          height={64}
          class="h-16 w-12"
        />
        <Image
          src={logoWordmark}
          alt=""
          width={112}
          height={32}
          class="h-8 w-28"
          aria-hidden="true"
        />
      </div>
      <button
        type="button"
        class="flex items-center justify-center rounded-full border border-n-500 p-3.5"
        aria-label="Open menu"
      >
        <Icon name="menu" class="h-5 w-5" aria-hidden="true" />
      </button>
    </div>

    <!-- Desktop Header -->
    <div class="mx-auto hidden w-full max-w-screen-2xl items-center justify-between px-5 py-4 lg:flex">
      <div class="flex items-center gap-0.5">
        <Image
          src={logoSymbol}
          alt="Chinook Driving School Calgary"
          width={48}
          height={64}
          class="h-16 w-12"
        />
        <Image
          src={logoWordmark}
          alt=""
          width={112}
          height={32}
          class="h-8 w-28"
          aria-hidden="true"
        />
      </div>

      <div class="flex items-center gap-11">
        <nav class="flex items-center gap-7 text-sm text-n-800" aria-label="Primary">
          {coursesHeroSectionData.navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "inline-flex flex-col items-center whitespace-nowrap",
                item.isActive ? "font-semibold text-n-900" : "font-medium text-n-800",
              ]}
            >
              <span>{item.label}</span>
              {item.isActive && (
                <span class="mt-2 h-0.5 w-14 rounded-lg bg-blue-500"></span>
              )}
            </a>
          ))}
        </nav>

        <div class="flex items-center gap-2.5">
          <a
            href={coursesHeroSectionData.cta.primaryHref}
            class="flex h-10 items-center justify-center rounded-3xl bg-blue-500 px-4 text-sm font-semibold leading-7 text-n-50"
          >
            {coursesHeroSectionData.cta.primaryLabel}
          </a>
          <button
            type="button"
            class="flex h-10 items-center justify-center gap-1.5 rounded-3xl border border-n-800 px-4 text-sm font-semibold leading-7 text-n-800"
          >
            {coursesHeroSectionData.cta.secondaryLabel}
            <Icon name="phone" class="h-[18px] w-[18px]" aria-hidden="true" />
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Hero Content -->
  <div class="mx-auto w-full max-w-screen-2xl px-6 pb-16 pt-11 md:pt-16 lg:px-5 lg:pb-32">
    <div class="flex flex-col gap-9 md:gap-10 lg:flex-row lg:items-end lg:justify-between">
      <div class="flex max-w-2xl flex-col gap-6 md:gap-7 lg:max-w-[691px] lg:gap-8">
        <h1 class="text-3xl font-bold leading-tight text-n-900 md:text-5xl lg:text-6xl">
          {coursesHeroSectionData.title}
        </h1>
        <p class="text-sm font-medium leading-6 text-n-700 md:text-lg md:leading-7 lg:text-xl">
          {coursesHeroSectionData.description}
          <span class="font-bold">{coursesHeroSectionData.emphasis}</span>
          {coursesHeroSectionData.descriptionSuffix}
        </p>
      </div>

      <div class="flex w-full items-center justify-center lg:w-auto">
        <div class="-scale-y-100 rotate-180">
          <div class="relative aspect-[7/5] w-full max-w-[700px] lg:h-[500px] lg:w-[700px]">
            <div class="absolute inset-0 overflow-hidden opacity-50">
              <Image
                src={heroIllustration}
                alt=""
                width={700}
                height={500}
                class="absolute left-0 top-0 h-[156%] w-full object-cover"
                aria-hidden="true"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
