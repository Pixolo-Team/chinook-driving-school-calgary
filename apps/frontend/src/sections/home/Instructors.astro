---
import InstructorCard from "@/components/InstructorCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import SliderArrows from "@/components/SliderArrows.astro";
import { getHomeInstructorsViewModel } from "@/data/site-content-mappers";

const instructorsViewModel = await getHomeInstructorsViewModel();
const sectionContent = {
  eyebrow: instructorsViewModel.eyebrow,
  heading: instructorsViewModel.heading,
  description: instructorsViewModel.description,
};
const instructors = instructorsViewModel.instructors;
const shouldCenterInstructorCards = instructors.length < 3;

---

<section class="bg-n-100" data-instructors-section>
  <div class="container mx-auto w-full px-6 py-20 md:px-12 lg:px-24 lg:py-28">

    <!-- Section Header -->
    <SectionHeader
      eyebrow={sectionContent.eyebrow}
      heading={sectionContent.heading}
      description={sectionContent.description}
    />

    <!-- Instructor Card Section -->
    <div class="carousel-wrapper relative mt-11 flex flex-col gap-5 lg:mt-16 lg:gap-16">
      <div class="embla overflow-hidden cursor-grab active:cursor-grabbing">
        <div class:list={["embla__container flex -ml-3", shouldCenterInstructorCards && "xl:justify-center"]}>

          <!-- Instructor Cards -->
          {instructors.map((instructor) => (
            <div class="embla__slide flex pl-3 cursor-default min-w-0 flex-[0_0_100%] md:flex-[0_0_50%] lg:pl-5 xl:flex-[0_0_33.33%]">
              <InstructorCard
                name={instructor.name}
                role={instructor.role}
                description={instructor.description}
              />
            </div>
          ))}
        </div>
      </div>
      
      <!-- Slider Arrows -->
      <SliderArrows />
    </div>
  </div>
</section>

<!-- Carousel Scripts -->
<script>
  import EmblaCarousel from "embla-carousel";
  import { initializeInstructorCards } from "@/scripts/instructorCards";

  // Initialize each instructor carousel on the page.
  const initCarousels = () => {
    const wrappers = document.querySelectorAll(".carousel-wrapper");

    wrappers.forEach((wrapper) => {
      if (!(wrapper instanceof HTMLElement) || wrapper.dataset.emblaInitialized === "true") {
        return;
      }

      wrapper.dataset.emblaInitialized = "true";

      const viewport = wrapper.querySelector(".embla") as HTMLElement;
      if (!viewport) return;

      const slideCount = viewport.querySelectorAll(".embla__slide").length;
      const shouldLoop = slideCount > 2;

      // Create the slider with responsive scroll groups.
      let emblaApi = EmblaCarousel(viewport, {
        loop: shouldLoop,
        align: "start",
        duration: 32,
        slidesToScroll: 1,
        breakpoints: {
          "(min-width: 768px)": { slidesToScroll: 2 },
          "(min-width: 1280px)": { slidesToScroll: 3 },
        },
      });

      const prevButtons = [...wrapper.querySelectorAll("[data-embla-prev]")].filter(
        (btn): btn is HTMLButtonElement => btn instanceof HTMLButtonElement,
      );
      const nextButtons = [...wrapper.querySelectorAll("[data-embla-next]")].filter(
        (btn): btn is HTMLButtonElement => btn instanceof HTMLButtonElement,
      );

      const updateArrowStates = () => {
        prevButtons.forEach((btn) => {
          btn.disabled = !emblaApi.canScrollPrev();
          btn.classList.toggle("opacity-40", btn.disabled);
        });

        nextButtons.forEach((btn) => {
          btn.disabled = !emblaApi.canScrollNext();
          btn.classList.toggle("opacity-40", btn.disabled);
        });
      };

      prevButtons.forEach((btn) => {
        const handlePrevClick = () => emblaApi.scrollPrev();
        btn.addEventListener("click", handlePrevClick);
      });

      nextButtons.forEach((btn) => {
        const handleNextClick = () => emblaApi.scrollNext();
        btn.addEventListener("click", handleNextClick);
      });

      const dotsContainer = wrapper.querySelector(".embla__dots");
      const dotsWrapper = wrapper.querySelector("[data-embla-dots-wrapper]") as HTMLElement | null;
      const mobileTabletArrows = wrapper.querySelector("[data-embla-mobile-arrows]") as HTMLElement | null;
      const desktopArrows = wrapper.querySelector("[data-embla-desktop-arrows]") as HTMLElement | null;
      let dotNodes: HTMLButtonElement[] = [];

      if (dotsContainer) {
        const updateControlsVisibility = () => {
          const slideCount = emblaApi.slideNodes().length;
          const isDesktop = window.matchMedia("(min-width: 1280px)").matches;
          const isTablet = window.matchMedia("(min-width: 768px)").matches && !isDesktop;
          const visibleCards = isDesktop ? 3 : isTablet ? 2 : 1;
          const showControls = slideCount > visibleCards;

          dotsWrapper?.classList.toggle("hidden", !showControls);

          if (mobileTabletArrows) {
            mobileTabletArrows.classList.toggle("hidden", isDesktop || !showControls);
            mobileTabletArrows.classList.toggle("flex", !isDesktop && showControls);
          }

          if (desktopArrows) {
            desktopArrows.classList.toggle("hidden", !isDesktop || !showControls);
            desktopArrows.classList.toggle("lg:flex", isDesktop && showControls);
          }
        };
        
        // Build one dot per scroll snap.
        const createDots = () => {
          const snapList = emblaApi.scrollSnapList();

          dotsContainer.innerHTML = snapList
            .map(
              (_, i) => `
            <button 
              class="h-2 w-2 rounded-full bg-n-300 transition-all duration-300 cursor-pointer" 
              type="button"
              aria-label="Go to group ${i + 1}"
            ></button>
          `,
            )
            .join("");

          dotNodes = Array.from(dotsContainer.querySelectorAll("button"));

          dotNodes.forEach((dot, i) => {
            const handleDotClick = () => emblaApi.scrollTo(i);
            dot.addEventListener("click", handleDotClick);
          });
        };

        // Highlight the active dot.
        const updateDots = () => {
          const selectedIndex = emblaApi.selectedScrollSnap();

          dotNodes.forEach((dot, index) => {
            if (index === selectedIndex) {
              dot.classList.remove("w-2", "bg-n-300");
              dot.classList.add("w-6", "bg-blue-600");
            } else {
              dot.classList.remove("w-6", "bg-blue-600");
              dot.classList.add("w-2", "bg-n-300");
            }
          });
        };

        createDots();
        updateDots();
        updateControlsVisibility();
        updateArrowStates();

        emblaApi.on("select", () => {
          updateDots();
          updateArrowStates();
        });

        emblaApi.on("reInit", () => {
          createDots();
          updateDots();
          updateControlsVisibility();
          updateArrowStates();
        });
      }
    });
  };

  // Run on first load and Astro page navigation.
  document.addEventListener("DOMContentLoaded", initCarousels);
  document.addEventListener("astro:page-load", initCarousels);
  document.addEventListener("DOMContentLoaded", initializeInstructorCards);
  document.addEventListener("astro:page-load", initializeInstructorCards);
</script>
