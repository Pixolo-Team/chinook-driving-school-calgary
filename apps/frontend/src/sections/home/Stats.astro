---
// COMPONENTS //
import StatCard from "@/components/StatCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";

// DATA //
import { numberStatsData } from "@/data/numberSection";
import { statHeaderData } from "@/data/numberSection";
import { getSiteContentData, isNonEmptyString } from "@/data/site-content-api";

const siteContentData = await getSiteContentData();
const statsApiData = siteContentData?.stats;

const statsHeader = {
  eyebrow: isNonEmptyString(statsApiData?.eyebrow) ? statsApiData.eyebrow : statHeaderData.eyebrow,
  heading: isNonEmptyString(statsApiData?.title) ? statsApiData.title : statHeaderData.heading,
};

const statsCardsFromApi =
  statsApiData?.stat_cards
    ?.filter(
      (statCard) =>
        isNonEmptyString(statCard.icon) &&
        isNonEmptyString(statCard.stat_number) &&
        isNonEmptyString(statCard.description),
    )
    .map((statCard) => ({
      icon: statCard.icon,
      value: `${statCard.stat_number}${statCard.stat_suffix ?? ""}`,
      label: statCard.description,
    })) ?? [];

const statsCards = statsCardsFromApi.length > 0 ? statsCardsFromApi : numberStatsData;

---

<section class="bg-n-100">
  <div class="container mx-auto flex w-full flex-col items-center gap-9 px-6 py-20 sm:px-0 sm:gap-10 lg:gap-12 lg:px-0 lg:py-28">
    
    <!-- Section Header -->
    <SectionHeader
      eyebrow={statsHeader.eyebrow}
      heading={statsHeader.heading}
    />

    <!-- StatCard -->
    <div class="grid w-70 grid-cols-1 gap-3.5 px-6 md:w-full md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
      {statsCards.map((stat) => (
        <StatCard icon={stat.icon} value={stat.value} label={stat.label} />
      ))}
    </div>
  </div>
</section>
