---
import FeatureCard from "@/components/FeatureCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { FeaturesSectionDetails } from "@/data/features";
import {
  getSiteContentData,
  isNonEmptyString,
  normalizeApiImagePath,
} from "@/data/site-content-api";

const siteContentData = await getSiteContentData();
const featuresApiData = siteContentData?.features;
const sectionContent = {
  eyebrow: isNonEmptyString(featuresApiData?.eyebrow)
    ? featuresApiData.eyebrow
    : FeaturesSectionDetails.content.eyebrow,
  title: isNonEmptyString(featuresApiData?.title)
    ? featuresApiData.title
    : FeaturesSectionDetails.content.title,
  description: isNonEmptyString(featuresApiData?.description)
    ? featuresApiData.description
    : FeaturesSectionDetails.content.description,
};

const featureCardsFromApi =
  featuresApiData?.feature_cards
    ?.filter(
      (featureCard) =>
        isNonEmptyString(featureCard.title) && isNonEmptyString(featureCard.description),
    )
    .map((featureCard) => ({
      title: featureCard.title,
      description: featureCard.description,
      imageAlt: featureCard.title,
      imageSrc: normalizeApiImagePath(featureCard.image) ?? "/images/features/certified-driving.png",
    })) ?? [];

const featureCards = featureCardsFromApi.length > 0 ? featureCardsFromApi : FeaturesSectionDetails.cards;
---

<section class="bg-n-50">
  <div
    class="container mx-auto flex w-full flex-col items-center gap-16 px-5 py-20 lg:px-0 lg:py-28"
  >
    <!-- Section Header -->
    <SectionHeader
      eyebrow={sectionContent.eyebrow}
      heading={sectionContent.title}
      description={sectionContent.description}
    />

    <!-- Feature Cards -->
    <div
      class="grid grid-cols-1 place-items-center gap-9 md:grid-cols-2 xl:grid-cols-3 xl:place-items-start 2xl:grid-cols-4"
    >
      {featureCards.map((cardItem) => <FeatureCard cardItem={cardItem} />)}
    </div>
  </div>
</section>
