---
// DATA //
import { founderSectionData } from "@/data/founder-section-data";
---

<section class="bg-n-50">
  <div class="container mx-auto flex w-full max-w-screen-2xl flex-col items-center gap-7 px-6 py-14 md:gap-12 md:px-8 lg:gap-14 lg:px-28">

    <!-- Header -->
    <div class="flex w-full flex-col items-center gap-1 text-center md:gap-2.5">
      <p class="text-xs font-bold uppercase tracking-[0.6px] text-blue-500 md:text-sm lg:text-base">
        {founderSectionData.eyebrow}
      </p>
      <p class="text-3xl font-bold leading-tight text-n-800 md:text-4xl lg:text-5xl">
        {founderSectionData.heading}
      </p>
    </div>

    <!-- Content -->
    <div class="flex w-full flex-col items-start gap-7 md:gap-14 lg:flex-row lg:items-center lg:gap-16">
      <div class="h-[283px] w-full rounded-3xl bg-n-100 md:h-[455px] md:rounded-4xl lg:h-[537px] lg:w-[465px]"></div>

      <div class="flex w-full flex-col gap-7 md:gap-11 lg:gap-12">
        <div class="flex w-full flex-col gap-4 text-sm leading-relaxed text-n-800 md:gap-5 md:text-base lg:gap-6 lg:text-lg">
          {founderSectionData.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>

        <div class="flex w-full items-center gap-2.5 border-t border-n-300 pt-4 md:gap-3.5 md:pt-5 lg:gap-4 lg:pt-6">
          <span class="h-12 w-1 bg-n-950"></span>
          <div class="flex flex-col items-start gap-1">
            <p class="text-lg font-bold text-n-700 md:text-xl">
              {founderSectionData.name}
            </p>
            <p class="text-xs font-semibold uppercase tracking-[1.4px] text-n-400 md:text-sm">
              {founderSectionData.title}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
