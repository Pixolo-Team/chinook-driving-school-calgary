---
// COMPONENTS //
import SectionHeader from "@/components/SectionHeader.astro";
import StoryCard from "@/components/StoryCard.astro";

// DATA //
import { aboutStorySectionData } from "@/data/about-story";
import { getSiteContentData, isNonEmptyString } from "@/data/site-content-api";

const siteContentData = await getSiteContentData();
const aboutStoryApiData = siteContentData?.about_story;

const content = {
  eyebrow: isNonEmptyString(aboutStoryApiData?.eyebrow)
    ? aboutStoryApiData.eyebrow
    : aboutStorySectionData.content.eyebrow,
  heading:
    isNonEmptyString(aboutStoryApiData?.title) && typeof aboutStoryApiData.title === "string"
      ? aboutStoryApiData.title
      : aboutStorySectionData.content.heading,
  story: isNonEmptyString(aboutStoryApiData?.description)
    ? aboutStoryApiData.description
    : aboutStorySectionData.content.story,
};

const cardsFromApi =
  aboutStoryApiData?.story_cards
    ?.filter((storyCard) => isNonEmptyString(storyCard.title) && isNonEmptyString(storyCard.description))
    .map((storyCard, index) => ({
      icon: aboutStorySectionData.cards[index]?.icon ?? "badge-award-star",
      title: storyCard.title,
      description: storyCard.description,
    })) ?? [];

const cards = cardsFromApi.length > 0 ? cardsFromApi : aboutStorySectionData.cards;
---

<section class="bg-n-50">
  <div
    class="container mx-auto flex w-full flex-col items-center gap-7 px-5 py-12 sm:gap-11 sm:px-6 sm:py-20 lg:gap-12 lg:py-20"
  >
    <div
      class="flex w-full max-w-4xl flex-col items-center gap-7 text-center sm:gap-11 lg:gap-12"
    >
      <SectionHeader
        eyebrow={content.eyebrow}
        heading={content.heading}
      />

      <p
        set:html={content.story}
        class="text-sm leading-[1.4] text-n-800 sm:text-base md:text-lg lg:text-xl"
      >
      </p>
    </div>

    <div class="grid w-full grid-cols-1 gap-3.5 sm:gap-4 lg:grid-cols-3 lg:gap-6">
      {cards.map((card, index) => (
        <StoryCard
          icon={card.icon}
          number={String(index + 1).padStart(2, "0")}
          title={card.title}
          description={card.description}
        />
      ))}
    </div>
  </div>
</section>
