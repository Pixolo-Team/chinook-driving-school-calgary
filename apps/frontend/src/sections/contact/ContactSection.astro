---
// DATA //
import { contactSectionData } from "@/data/contact-section-data";

// COMPONENTS //
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

const { cards } = contactSectionData;
---

<section class="bg-n-50">
  <div
    class="container mx-auto flex w-full max-w-screen-2xl flex-col items-center gap-10 px-5 py-16 sm:px-6 md:py-20 lg:gap-11 lg:px-10 lg:py-28"
  >
    <div class="flex max-w-3xl flex-col items-center gap-2.5 text-center">
      <p class="text-xs font-bold uppercase tracking-[0.6px] text-blue-600 sm:text-sm">
        {contactSectionData.eyebrow}
      </p>
      <p class="text-2xl font-bold leading-tight text-n-800 sm:text-3xl md:text-4xl lg:text-5xl">
        {contactSectionData.heading}
      </p>
      <p class="text-sm text-n-600 sm:text-base">
        {contactSectionData.description}
      </p>
    </div>

    <div class="flex w-full flex-col gap-5 lg:gap-6">
      <div class="grid w-full gap-5 lg:grid-cols-2 lg:gap-6">
        <div class="relative flex overflow-hidden rounded-4xl border border-n-200 bg-n-50 p-4 sm:p-5 lg:p-6">
          <div class="pointer-events-none absolute -left-20 -top-20 size-64 rounded-full bg-blue-100 opacity-30"></div>
          <div class="hidden w-32 shrink-0 items-end md:flex">
            <Image
              src={cards.getInTouch.image}
              alt="Instructor ready to help"
              width={126}
              height={193}
              class="h-auto w-full object-contain"
            />
          </div>
          <div class="flex flex-1 flex-col gap-4 sm:gap-5">
            <div class="flex flex-col gap-3">
              <p class="text-lg font-bold text-n-800 sm:text-xl">
                {cards.getInTouch.title}
              </p>
              <span class="h-0.5 w-full bg-blue-600"></span>
            </div>
            <div class="flex flex-col gap-3">
              {cards.getInTouch.details.map((detail) => (
                <div class="flex items-center gap-4">
                  <div class="flex size-8 items-center justify-center rounded-full bg-n-100 sm:size-9">
                    <Icon name={detail.icon} class="size-4 text-n-800" aria-hidden="true" />
                  </div>
                  <p class="text-sm font-medium text-n-800 sm:text-base">{detail.value}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="relative flex overflow-hidden rounded-4xl border border-n-200 bg-n-50 p-4 sm:p-5 lg:p-6">
          <div class="pointer-events-none absolute -left-20 -top-20 size-64 rounded-full bg-blue-100 opacity-30"></div>
          <div class="hidden w-32 shrink-0 items-end md:flex">
            <Image
              src={cards.openingHours.image}
              alt="Instructor checking schedule"
              width={126}
              height={193}
              class="h-auto w-full object-contain"
            />
          </div>
          <div class="flex flex-1 flex-col gap-4 sm:gap-5">
            <div class="flex flex-col gap-3">
              <p class="text-lg font-bold text-n-800 sm:text-xl">
                {cards.openingHours.title}
              </p>
              <span class="h-0.5 w-full bg-blue-600"></span>
            </div>
            <div class="flex flex-col gap-3">
              {cards.openingHours.details.map((detail) => (
                <div class="flex items-center gap-4">
                  <div class="flex size-8 items-center justify-center rounded-full bg-n-100 sm:size-9">
                    <Icon name={detail.icon} class="size-4 text-n-800" aria-hidden="true" />
                  </div>
                  <p class="text-sm text-n-800 sm:text-base">
                    <span class="font-semibold">{detail.label}</span> {detail.value}
                  </p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="relative flex flex-col gap-6 overflow-hidden rounded-4xl border border-n-200 bg-n-50 p-5 sm:p-7 md:flex-row md:items-start md:gap-11 lg:p-10">
        <div class="pointer-events-none absolute -left-32 -top-24 size-96 rounded-full bg-blue-100 opacity-30"></div>
        <div class="hidden w-40 shrink-0 items-end md:flex lg:w-44">
          <Image
            src={cards.officeDetails.image}
            alt="Student ready for a lesson"
            width={181}
            height={281}
            class="h-auto w-full object-contain"
          />
        </div>
        <div class="flex flex-1 flex-col gap-4 sm:gap-5">
          <div class="flex flex-col gap-3">
            <p class="text-lg font-bold text-n-800 sm:text-xl">
              {cards.officeDetails.title}
            </p>
            <span class="h-0.5 w-full max-w-40 bg-blue-600"></span>
          </div>
          <div class="flex flex-col gap-4 sm:gap-5">
            {cards.officeDetails.locations.map((location, index) => (
              <div class="flex flex-col gap-4">
                <div class="flex items-start gap-4">
                  <div class="flex size-9 items-center justify-center rounded-full bg-n-100">
                    <Icon name={location.icon} class="size-4 text-n-800" aria-hidden="true" />
                  </div>
                  <div class="flex flex-1 flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex flex-col gap-1 text-sm text-n-900 sm:text-base">
                      <p class="font-semibold">{location.name}</p>
                      <p class="text-n-600">{location.address}</p>
                    </div>
                    <button
                      type="button"
                      class="flex w-fit items-center gap-2 rounded-full bg-blue-500 px-4 py-1.5 text-sm font-semibold text-n-50"
                    >
                      {location.actionLabel}
                      <Icon
                        name="diagonal-line-arrow-upper-right"
                        class="size-3.5 text-n-50"
                        aria-hidden="true"
                      />
                    </button>
                  </div>
                </div>
                {index === 0 && <div class="h-px w-full bg-n-200"></div>}
              </div>
            ))}
            <div class="h-px w-full bg-n-200"></div>
            <div class="flex items-start gap-4">
              <div class="flex size-9 items-center justify-center rounded-full bg-n-100">
                <Icon name={cards.officeDetails.serviceArea.icon} class="size-4 text-n-800" aria-hidden="true" />
              </div>
              <div class="flex flex-col gap-1 text-sm text-n-900 sm:text-base">
                <p class="font-semibold">{cards.officeDetails.serviceArea.label}</p>
                <p class="text-n-600">{cards.officeDetails.serviceArea.value}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
