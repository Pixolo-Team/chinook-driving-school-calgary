---
// COMPONENTS //
import HeroCard from "@/components/HeroCard.astro";

// DATA //
import { contactHeroSectionData } from "@/data/contact";
import { getSiteContentData, isNonEmptyString } from "@/data/site-content-api";

const siteContentData = await getSiteContentData();
const contactHeroApiData = siteContentData?.contact_hero;

const heroContent = {
  title: isNonEmptyString(contactHeroApiData?.title)
    ? contactHeroApiData.title
    : contactHeroSectionData.title,
  description: isNonEmptyString(contactHeroApiData?.description)
    ? contactHeroApiData.description
    : contactHeroSectionData.description,
};
---

<section class="bg-n-100 overflow-hidden">
  <HeroCard
    title={heroContent.title}
    description={heroContent.description}
    illustration={contactHeroSectionData.illustration}
    illustrationAlt={contactHeroSectionData.illustrationAlt}
    flipImage={true}
  />
</section>
