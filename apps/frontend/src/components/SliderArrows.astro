---
// COMPONENTS //
import { Image } from "astro:assets";

// IMAGES //
import arrowLeftMobile from "@/assets/instructor-arrow-left.png";
import arrowRightMobile from "@/assets/instructor-arrow-right.png";
import arrowIcon from "@/assets/instructor-arrow-icon.png";
---

<div class="relative flex w-full items-center justify-end">
  
  <div class="absolute left-1/2 top-5 -translate-x-1/2">
    <div class="embla__dots flex items-center justify-center gap-2"></div>
  </div>

  <div class="hidden items-center gap-4 lg:flex">
    <button
      type="button"
      data-embla-prev
      class="animate-bouncy-hover relative z-10 flex cursor-pointer items-center justify-center rounded-3xl border border-n-300 bg-n-50 p-3.5 transition-colors hover:bg-n-100"
      aria-label="Previous instructor"
    >
      <Image src={arrowIcon} alt="" width={20} height={20} class="pointer-events-none rotate-180" aria-hidden="true" />
    </button>
    <button
      type="button"
      data-embla-next
      class="animate-bouncy-hover relative z-10 flex cursor-pointer items-center justify-center rounded-3xl border border-n-300 bg-n-50 p-3.5 transition-colors hover:bg-n-100"
      aria-label="Next instructor"
    >
      <Image src={arrowIcon} alt="" width={20} height={20} class="pointer-events-none" aria-hidden="true" />
    </button>
  </div>

  <div class="flex items-center gap-3 lg:hidden">
    <button type="button" data-embla-prev aria-label="Previous instructor" class="animate-bouncy-hover relative z-10 cursor-pointer">
      <Image src={arrowLeftMobile} alt="" width={36} height={36} class="pointer-events-none rotate-180" aria-hidden="true" />
    </button>
    <button type="button" data-embla-next aria-label="Next instructor" class="animate-bouncy-hover relative z-10 cursor-pointer">
      <Image src={arrowRightMobile} alt="" width={36} height={36} class="pointer-events-none" aria-hidden="true" />
    </button>
  </div>
</div>
