---
import { Icon } from "astro-icon/components";
---

<div class="relative flex w-full items-center justify-end">
  
  <div class="absolute left-1/2 top-5 -translate-x-1/2">
    <div class="embla__dots flex items-center justify-center gap-2"></div>
  </div>

  <div class="hidden items-center gap-4 lg:flex">
    <button
      type="button"
      data-embla-prev
      class="animate-bouncy-hover relative z-10 flex cursor-pointer items-center justify-center rounded-3xl border border-n-200 bg-blue-50 p-3.5 text-blue-700 transition-colors hover:bg-blue-100 hover:text-blue-800"
      aria-label="Previous instructor"
    >
      <Icon name="carousel-arrow" class="pointer-events-none size-4 rotate-180" aria-hidden="true" />
    </button>
    <button
      type="button"
      data-embla-next
      class="animate-bouncy-hover relative z-10 flex cursor-pointer items-center justify-center rounded-3xl border border-n-200 bg-blue-50 p-3.5 text-blue-700 transition-colors hover:bg-blue-100 hover:text-blue-800"
      aria-label="Next instructor"
    >
      <Icon name="carousel-arrow" class="pointer-events-none size-4" aria-hidden="true" />
    </button>
  </div>

  <div class="flex items-center gap-3 lg:hidden">
    <button
      type="button"
      data-embla-prev
      aria-label="Previous instructor"
      class="animate-bouncy-hover relative z-10 flex h-11 w-11 cursor-pointer items-center justify-center rounded-3xl border border-blue-200 bg-blue-50 p-1.5 text-blue-700 transition-colors hover:bg-blue-100 hover:text-blue-800"
    >
      <Icon name="carousel-arrow" class="pointer-events-none size-4 rotate-180" aria-hidden="true" />
    </button>
    <button
      type="button"
      data-embla-next
      aria-label="Next instructor"
      class="animate-bouncy-hover relative z-10 flex h-11 w-11 cursor-pointer items-center justify-center rounded-3xl border border-blue-200 bg-blue-50 p-1.5 text-blue-700 transition-colors hover:bg-blue-100 hover:text-blue-800"
    >
      <Icon name="carousel-arrow" class="pointer-events-none size-4" aria-hidden="true" />
    </button>
  </div>
</div>
