---
// COMPONENTS //
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import Button from "@/components/ui/Button.astro";
import Chip from "@/components/ui/Chip.astro";

// CONSTANTS //
import { URLS } from "@/infrastructure/constants/urls";

// SVG's //
import ellipseLight from "@/assets/ellipse-light.svg";
import ellipseBlue from "@/assets/ellipse-blue.svg";
import ellipseLightAlt from "@/assets/ellipse-light-alt.svg";

const ellipseMap = {
  light: ellipseLight,
  blue: ellipseBlue,
  "light-alt": ellipseLightAlt,
};

interface CourseCardProps {
  title: string;
  price: string;
  duration: string;
  practice: {
    label: string;
    value: string;
  };
  classroom: {
    label: string;
    value: string;
  };
  features: string[];
  theme: "light" | "brand";
  ellipse: keyof typeof ellipseMap;
  badge?: string;
}

const card = Astro.props as CourseCardProps;
---

<div class="relative flex h-full w-full">
  {
    card.badge && (
      <div class="absolute top-0 left-1/2 z-20 hidden -translate-x-1/2 -translate-y-1/2 md:block">
        <div class="bg-n-50 inline-flex min-h-8.75 items-center justify-center rounded-full border-2 border-blue-500 px-5 py-2 text-center text-xs leading-none font-bold whitespace-nowrap text-blue-500 lg:px-6 lg:text-sm">
          {card.badge}
        </div>
      </div>
    )
  }

  <div
    class:list={[
      "relative flex h-full w-full flex-col justify-between overflow-hidden rounded-4xl border p-5 lg:p-6 2xl:p-10",
      card.theme === "brand"
        ? "text-n-50 border-blue-500 bg-blue-500"
        : "border-n-300 bg-n-50 text-n-800",
    ]}
  >
    <Image
      src={ellipseMap[card.ellipse]}
      alt=""
      width={353}
      height={353}
      class:list={[
        "pointer-events-none absolute -right-36 -bottom-22 w-56 opacity-100 md:-right-22 md:-bottom-30 lg:w-60 2xl:-right-26 2xl:-bottom-36 2xl:w-72",
        card.theme === "brand" ? "opacity-90" : "opacity-100",
      ]}
      aria-hidden="true"
    />

    <div class="relative z-10 flex flex-col gap-5 lg:gap-6">
      <div class="flex items-start justify-between gap-3">
        <div class="flex min-w-0 flex-1 flex-col gap-3">
          <p
            class:list={[
              "text-sm leading-tight font-bold tracking-[1.4px] uppercase",
              card.theme === "brand" ? "text-n-50" : "text-blue-500",
            ]}
          >
            {card.title}
          </p>
          <div class="flex items-end gap-1">
            <p
              class:list={[
                "text-3xl leading-none font-bold lg:text-4xl 2xl:text-5xl",
                card.theme === "brand" ? "text-n-50" : "text-n-800",
              ]}
            >
              {card.price}
            </p>
            <p
              class:list={[
                "text-sm font-semibold",
                card.theme === "brand" ? "text-n-200" : "text-n-500",
              ]}
            >
              +GST
            </p>
          </div>
        </div>

        <div class="shrink-0 self-start">
          <Chip duration={card.duration} theme={card.theme} />
        </div>
      </div>

      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div class="flex flex-1 items-center gap-3 2xl:flex-none">
            <div
              class:list={[
                "flex size-8 items-center justify-center rounded-2xl",
                card.theme === "brand" ? "bg-n-50/13" : "bg-blue-500/10 text-blue-500",
              ]}
            >
              <Icon
                name={card.theme === "brand" ? "steering-wheel-inverse" : "steering-wheel"}
                class:list={["size-4", card.theme === "brand" ? "text-n-50" : "text-n-800"]}
                aria-hidden="true"
              />
            </div>
            <div class="flex flex-col leading-tight">
              <p
                class:list={[
                  "text-xs font-medium",
                  card.theme === "brand" ? "text-n-200" : "text-n-500",
                ]}
              >
                {card.practice.label}
              </p>
              <p
                class:list={[
                  "text-lg leading-tight font-bold",
                  card.theme === "brand" ? "text-n-50" : "text-n-800",
                ]}
              >
                {card.practice.value}
              </p>
            </div>
          </div>

          <div
            class:list={[
              "hidden h-8 w-px md:block",
              card.theme === "brand" ? "bg-n-50/30" : "bg-n-200",
            ]}
          >
          </div>

          <div
            class:list={[
              "block h-px w-full md:hidden",
              card.theme === "brand" ? "bg-blue-200" : "bg-n-200",
            ]}
          >
          </div>

          <div class="flex flex-1 items-center gap-3">
            <div
              class:list={[
                "flex size-8 items-center justify-center rounded-2xl",
                card.theme === "brand" ? "bg-n-50/13" : "bg-blue-500/10 text-blue-500",
              ]}
            >
              <Icon
                name={card.theme === "brand"
                  ? "whiteboard-classroom-course-inverse"
                  : "whiteboard-classroom-course"}
                class:list={["size-4", card.theme === "brand" ? "text-n-50" : "text-n-800"]}
                aria-hidden="true"
              />
            </div>
            <div class="flex flex-col leading-tight">
              <p
                class:list={[
                  "text-xs font-medium",
                  card.theme === "brand" ? "text-n-200" : "text-n-500",
                ]}
              >
                {card.classroom.label}
              </p>
              <p
                class:list={[
                  "text-lg leading-tight font-bold",
                  card.theme === "brand" ? "text-n-50" : "text-n-800",
                ]}
              >
                {card.classroom.value}
              </p>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-2.5">
          {
            card.features.map((feature) => (
              <div class="flex items-start gap-3">
                <Icon
                  name={card.theme === "brand" ? "check-circle-inverse" : "check-circle"}
                  class:list={[
                    "mt-0.5 size-4 shrink-0",
                    card.theme === "brand" ? "text-n-50" : "text-green-500",
                  ]}
                  aria-hidden="true"
                />
                <p
                  class:list={[
                    "text-sm leading-snug",
                    card.theme === "brand" ? "text-n-50 font-semibold" : "text-n-800 font-normal",
                  ]}
                >
                  {feature}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="relative z-10">
      <Button value="Select Package" theme={card.theme} href={URLS.ENROLL} />
    </div>
  </div>
</div>
