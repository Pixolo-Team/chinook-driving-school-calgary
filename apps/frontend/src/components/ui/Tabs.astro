---
interface TabsProps {
  items: string[];
  activeIndex?: number;
}

const { items, activeIndex = 0 } = Astro.props as TabsProps;
---

<div
  data-tabs
  class="relative flex w-full items-center rounded-full border border-n-200 bg-n-50 p-1"
>
  <div
    data-tab-indicator
    class="absolute inset-y-1 left-0 rounded-full bg-blue-500 shadow-[0_8px_16px_rgba(19,127,236,0.18)] transition-transform duration-300 ease-out"
    style="width: 0px; transform: translateX(0px);"
  ></div>
  {
    items.map((item, index) => (
      <button
        type="button"
        data-tab-button
        data-tab-index={index}
        data-active={index === activeIndex ? "true" : "false"}
        aria-pressed={index === activeIndex ? "true" : "false"}
        class:list={[
          "animate-bouncy-hover relative z-10 flex min-w-0 flex-1 cursor-pointer items-center justify-center rounded-full px-3 py-3 text-center text-xs font-semibold leading-tight whitespace-normal transition-colors duration-300 ease-out sm:text-sm lg:text-base",
          index === activeIndex ? "text-n-50" : "text-n-600",
        ]}
      >
        {item}
      </button>
    ))
  }
</div>

<script>
  const activeClasses = ["text-n-50"];
  const inactiveClasses = ["text-n-600"];

  const syncIndicator = (
    tabs: Element,
    targetButton: HTMLButtonElement,
  ) => {
    const indicator = tabs.querySelector("[data-tab-indicator]");

    if (!(indicator instanceof HTMLElement) || !(tabs instanceof HTMLElement)) {
      return;
    }

    indicator.style.width = `${targetButton.offsetWidth}px`;
    indicator.style.transform = `translateX(${targetButton.offsetLeft}px)`;
  };

  document.querySelectorAll("[data-tabs]").forEach((tabs) => {
    if (tabs.dataset.initialized === "true") {
      return;
    }

    tabs.dataset.initialized = "true";

    const initialActiveButton = tabs.querySelector('[data-tab-button][data-active="true"]');

    if (initialActiveButton instanceof HTMLButtonElement) {
      syncIndicator(tabs, initialActiveButton);
    }

    tabs.addEventListener("click", (event) => {
      const button = event.target instanceof Element
        ? event.target.closest("[data-tab-button]")
        : null;

      if (!(button instanceof HTMLButtonElement) || !tabs.contains(button)) {
        return;
      }

      const buttons = tabs.querySelectorAll("[data-tab-button]");
      syncIndicator(tabs, button);

      buttons.forEach((tabButton) => {
        tabButton.dataset.active = "false";
        tabButton.setAttribute("aria-pressed", "false");
        tabButton.classList.remove(...activeClasses);
        tabButton.classList.add(...inactiveClasses);
      });

      button.dataset.active = "true";
      button.setAttribute("aria-pressed", "true");
      button.classList.remove(...inactiveClasses);
      button.classList.add(...activeClasses);
    });

    window.addEventListener("resize", () => {
      const activeButton = tabs.querySelector('[data-tab-button][data-active="true"]');

      if (activeButton instanceof HTMLButtonElement) {
        syncIndicator(tabs, activeButton);
      }
    });
  });
</script>
