---
interface TabsProps {
  items: string[];
  activeIndex?: number;
  controlsPanels?: boolean;
  activeTextClass?: string;
  inactiveTextClass?: string;
}

const {
  items,
  activeIndex = 0,
  controlsPanels = false,
  activeTextClass = "text-white",
  inactiveTextClass = "text-n-500",
} = Astro.props as TabsProps;
---

<div
  data-tabs
  data-tabs-controls-panels={controlsPanels ? "true" : undefined}
  data-active-text-class={activeTextClass}
  data-inactive-text-class={inactiveTextClass}
  role="tablist"
  class="relative flex w-full items-center rounded-full border border-n-200 bg-n-50 p-1"
>
  <div
    data-tab-indicator
    class="absolute inset-y-1 left-0 rounded-full bg-blue-500 shadow-[0_8px_16px_rgba(19,127,236,0.18)] transition-transform duration-300 ease-out"
    style="width: 0px; transform: translateX(0px);"
  ></div>
  {
    items.map((item, index) => (
      <button
        type="button"
        data-tab-button
        data-tab-index={index}
        data-active={index === activeIndex ? "true" : "false"}
        role="tab"
        aria-selected={index === activeIndex ? "true" : "false"}
        tabindex={index === activeIndex ? "0" : "-1"}
        class:list={[
          "animate-bouncy-hover relative z-10 flex min-w-0 flex-1 cursor-pointer items-center justify-center rounded-full px-3 py-3 text-center text-xs font-semibold leading-tight whitespace-normal transition-colors duration-300 ease-out sm:text-sm lg:text-base",
          index === activeIndex ? activeTextClass : inactiveTextClass,
        ]}
      >
        {item}
      </button>
    ))
  }
</div>

<script>
  const getClassList = (value: string | undefined, fallback: string) =>
    (value || fallback).split(" ").filter(Boolean);

  let tabsInstanceCount = 0;

  // Keep the sliding indicator aligned with the active tab.
  const syncIndicator = (
    tabs: Element,
    targetButton: HTMLButtonElement,
  ) => {
    const indicator = tabs.querySelector("[data-tab-indicator]");

    if (!(indicator instanceof HTMLElement) || !(tabs instanceof HTMLElement)) {
      return;
    }

    indicator.style.width = `${targetButton.offsetWidth}px`;
    indicator.style.transform = `translateX(${targetButton.offsetLeft}px)`;
  };

  // Only wire panels when the component is explicitly opted in.
  const getPanels = (tabs: HTMLElement) => {
    if (tabs.dataset.tabsControlsPanels !== "true") {
      return [];
    }

    const scope = tabs.closest("[data-process-section], [data-courses-section]");

    if (!(scope instanceof HTMLElement)) {
      return [];
    }

    return [...scope.querySelectorAll("[data-tab-panel]")];
  };

  // Update button state and show the matching panel.
  const activateTab = (
    tabs: HTMLElement,
    buttons: HTMLButtonElement[],
    panels: HTMLElement[],
    activeIndex: number,
  ) => {
    const activeButton = buttons[activeIndex];
    const activeClasses = getClassList(tabs.dataset.activeTextClass, "text-white");
    const inactiveClasses = getClassList(tabs.dataset.inactiveTextClass, "text-white");

    if (!(activeButton instanceof HTMLButtonElement)) {
      return;
    }

    syncIndicator(tabs, activeButton);

    buttons.forEach((button, index) => {
      const isActive = index === activeIndex;

      button.dataset.active = isActive ? "true" : "false";
      button.setAttribute("aria-selected", isActive ? "true" : "false");
      button.setAttribute("tabindex", isActive ? "0" : "-1");
      button.classList.remove(...(isActive ? inactiveClasses : activeClasses));
      button.classList.add(...(isActive ? activeClasses : inactiveClasses));
    });

    panels.forEach((panel, index) => {
      const isActive = index === activeIndex;

      panel.dataset.active = isActive ? "true" : "false";
      panel.hidden = !isActive;
    });
  };

  document.querySelectorAll("[data-tabs]").forEach((tabs) => {
    if (!(tabs instanceof HTMLElement) || tabs.dataset.initialized === "true") {
      return;
    }

    tabs.dataset.initialized = "true";
    tabsInstanceCount += 1;

    const buttons = [...tabs.querySelectorAll("[data-tab-button]")].filter(
      (button): button is HTMLButtonElement => button instanceof HTMLButtonElement,
    );
    const panels = getPanels(tabs);
    const instanceId = `tabs-${tabsInstanceCount}`;

    // Generate stable IDs so tabs and panels stay linked for accessibility.
    buttons.forEach((button, index) => {
      button.id = `${instanceId}-tab-${index}`;

      if (panels[index] instanceof HTMLElement) {
        panels[index].id = `${instanceId}-panel-${index}`;
        panels[index].setAttribute("role", "tabpanel");
        panels[index].setAttribute("aria-labelledby", button.id);
        button.setAttribute("aria-controls", panels[index].id);
      }
    });

    const initialActiveIndex = Math.max(
      buttons.findIndex((button) => button.dataset.active === "true"),
      0,
    );

    if (buttons.length > 0) {
      activateTab(tabs, buttons, panels, initialActiveIndex);
    }

    tabs.addEventListener("click", (event) => {
      const button = event.target instanceof Element
        ? event.target.closest("[data-tab-button]")
        : null;

      if (!(button instanceof HTMLButtonElement) || !tabs.contains(button)) {
        return;
      }

      const activeIndex = buttons.indexOf(button);
      if (activeIndex === -1) {
        return;
      }

      activateTab(tabs, buttons, panels, activeIndex);
      button.focus();
    });

    // Support standard tab keyboard navigation.
    tabs.addEventListener("keydown", (event) => {
      if (!["ArrowRight", "ArrowLeft", "Home", "End"].includes(event.key)) {
        return;
      }

      const currentIndex = Math.max(
        buttons.findIndex((button) => button.getAttribute("aria-selected") === "true"),
        0,
      );

      let nextIndex = currentIndex;

      if (event.key === "ArrowRight") {
        nextIndex = (currentIndex + 1) % buttons.length;
      } else if (event.key === "ArrowLeft") {
        nextIndex = (currentIndex - 1 + buttons.length) % buttons.length;
      } else if (event.key === "Home") {
        nextIndex = 0;
      } else if (event.key === "End") {
        nextIndex = buttons.length - 1;
      }

      event.preventDefault();
      activateTab(tabs, buttons, panels, nextIndex);
      buttons[nextIndex]?.focus();
    });

    // Recalculate the indicator position after layout changes.
    window.addEventListener("resize", () => {
      const activeIndex = buttons.findIndex((button) => button.dataset.active === "true");
      const activeButton = buttons[activeIndex];

      if (activeButton instanceof HTMLButtonElement) {
        syncIndicator(tabs, activeButton);
      }
    });
  });
</script>
