---
import type { ImageMetadata } from "astro";

import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  illustration: ImageMetadata;
  illustrationAlt?: string;
  flipImage?: boolean; 
}

const {
  title,
  description,
  illustration,
  illustrationAlt = title,
  flipImage = false, 
} = Astro.props as Props;
---

<div class="container mx-auto flex flex-col gap-9 px-6 pt-22 md:gap-10 md:px-8 lg:px-4 lg:flex-row lg:justify-between lg:pt-24">
  <div class="flex flex-col gap-6 md:gap-7 lg:max-w-[34rem] lg:flex-[1.05] lg:gap-8 lg:self-end lg:pb-32">
    <p class="text-3xl font-bold leading-tight text-n-900 md:text-5xl lg:text-6xl">
      {title}
    </p>
    <p class="text-sm font-medium leading-6 text-n-700 md:text-lg md:leading-7 lg:text-xl">
      {description}
    </p>
  </div>

  <div class="flex h-[233px] w-full overflow-hidden opacity-50 md:h-[420px] lg:min-w-0 lg:flex-[0.90] lg:self-end lg:h-[500px] xl:h-[540px]">
    <Image
      src={illustration}
      alt={illustrationAlt}
      class={`h-full w-full object-cover object-top grayscale md:object-[center_top_8%] lg:object-top ${
    flipImage ? "scale-x-[-1]" : ""
  }`}
    />
  </div>
</div>
