---
import { Image } from "astro:assets";

import badgeImage from "@/assets/instructor-badge.png";

interface Props {
  name: string;
  role: string;
  description: string;
}

const { name, role, description } = Astro.props;
---

<div class="relative h-60 w-full overflow-hidden rounded-3xl border border-n-200 bg-n-50 px-9 py-7 lg:h-84 lg:px-11 lg:py-9">
  
  <!-- Background Ellipse -->
  <div
    class="absolute bottom-32 -right-42 size-89 rounded-full bg-blue-100 opacity-40 lg:bottom-60 lg:-right-40"
    aria-hidden="true"
  >
  </div>

  <!-- Content -->
  <div class="relative flex h-full flex-col gap-6 lg:gap-8">
    <div class="flex items-start justify-between gap-6">
      
      <!-- Instructor Name and Role -->
      <div class="flex flex-col gap-3 lg:gap-4">
        <p class="text-2xl font-bold leading-tight text-n-800 lg:text-3xl">
          {name}
        </p>
        <p class="text-xs font-semibold uppercase tracking-[1.4px] text-n-500 lg:text-sm">
          {role}
        </p>
      </div>

      
      <!-- Instructor Badge -->
      <div class="relative shrink-0">
        <Image
          src={badgeImage}
          alt=""
          width={92}
          height={111}
          class="w-16 lg:w-23"
          aria-hidden="true"
        />
        <div class="absolute left-2.75 top-2.75 flex size-10 items-center justify-center rounded-full bg-n-50 lg:left-[16px] lg:top-[16px] lg:size-[60px]">
          <span class="text-[6px] font-bold uppercase text-n-800 lg:text-[10px]">
            CERTIFIED
          </span>
        </div>
      </div>
    </div>

    <!-- Instructor Description -->
    <p class="text-xs leading-relaxed text-n-600 lg:text-sm">
      {description}
    </p>
  </div>
</div>
