---
import { Image } from "astro:assets";
import logoMark from "@/../public/images/footer-logo-mark.svg";
import logoTextInline from "@/assets/brand/footer-logo-text-current.svg?raw";

interface Props {
  containerClass?: string;
  markClass?: string;
  textClass?: string;
  textAlt?: string;
  wordmarkColorClass?: string;
}

const {
  containerClass = "inline-flex h-14 items-center gap-0.5",
  markClass = "h-full w-auto shrink-0 object-contain",
  textClass = "h-8 w-auto shrink-0 object-contain",
  textAlt = "Chinook Driving Academy",
  wordmarkColorClass = "text-[var(--color-brand-logo-wordmark)]",
} = Astro.props as Props;
---

<div class={containerClass} role="img" aria-label={textAlt}>
  <Image
    src={logoMark}
    alt=""
    width={65}
    height={82}
    class={markClass}
    loading="lazy"
    aria-hidden="true"
  />
  <div
    class:list={[textClass, wordmarkColorClass]}
    aria-hidden="true"
    set:html={logoTextInline}
  />
</div>
