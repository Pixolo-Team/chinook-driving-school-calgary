---
import { Image } from "astro:assets";
import { footerSectionData } from "@/data/footer-section-data";

interface Props {
  containerClass?: string;
  markClass?: string;
  textClass?: string;
  textAlt?: string;
}

const {
  containerClass = "inline-flex h-14 items-center gap-0.5",
  markClass = "h-full w-auto shrink-0 object-contain",
  textClass = "h-8 w-auto shrink-0 object-contain",
  textAlt = footerSectionData.logo.alt,
} = Astro.props as Props;
---

<div class={containerClass} role="img" aria-label={textAlt}>
  <Image
    src={footerSectionData.logo.mark}
    alt=""
    width={65}
    height={82}
    class={markClass}
    loading="lazy"
    aria-hidden="true"
  />
  <Image
    src={footerSectionData.logo.text}
    alt={textAlt}
    width={144}
    height={42}
    class={textClass}
    loading="lazy"
  />
</div>
