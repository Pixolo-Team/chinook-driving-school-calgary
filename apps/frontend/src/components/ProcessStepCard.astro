---
interface ProcessStepCardProps {
  index: number;
  title: string;
  description: string;
}

const { index, title, description } = Astro.props as ProcessStepCardProps;
const stepNumber = String(index + 1).padStart(2, "0");
---

<div
  data-process-step-card
  class="relative flex h-full flex-col overflow-hidden rounded-4xl border border-n-300 bg-n-50 p-8 md:p-9 xl:p-10"
  style="opacity: 0; transform: translateX(32px);"
>
  
  <!-- Ellipse Background -->
  <div
    class="absolute -bottom-56 -left-64 size-89 rounded-full bg-blue-100 opacity-40"
    aria-hidden="true"
  >
  </div>

  <!-- Step Content -->
  <div class="relative flex flex-col gap-6">
   
    <!-- Step Index -->
    <p class="text-4xl font-bold leading-none text-blue-500 xl:text-5xl">
      {stepNumber}
    </p>

    <!-- Step Title and Description -->
    <div class="flex flex-col gap-3">
      <p class="text-lg font-bold leading-snug text-n-700 md:text-xl xl:text-2xl">
        {title}
      </p>

      <p class="text-sm leading-relaxed text-n-600 xl:text-base">
        {description}
      </p>
    </div>
  </div>
</div>
