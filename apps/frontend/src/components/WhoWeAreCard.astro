---
import { Icon } from "astro-icon/components";

interface WhoWeAreCardProps {
  icon: string;
  number: string;
  title: string;
  description: string;
}

const { icon, number, title, description } = Astro.props as WhoWeAreCardProps;
---

<div
  class="relative flex h-full w-full flex-col gap-3.5 overflow-hidden rounded-3xl border border-n-200 px-5 pt-3.5 pb-7 sm:gap-5 sm:px-7 sm:pt-5 sm:pb-9 lg:gap-6 "
>

<!-- Index Number -->
<p
    class="absolute -bottom-2 -right-1 z-0 text-8xl font-bold leading-none text-blue-50 md:text-9xl md:-bottom-4 lg:-right-3"
    aria-hidden="true"
  >
    {number}
</p>

  <!-- Icon -->
  <Icon
    name={icon}
    class="relative z-10 size-8 sm:size-10 lg:size-11"
    aria-hidden="true"
  />

  <!-- Title & Description -->
  <div class="relative z-10 flex flex-col gap-1">
    <p class="text-lg font-bold text-n-800 sm:text-xl lg:text-2xl">
      {title}
    </p>

    <p class="text-xs text-n-800 lg:text-base">
      {description}
    </p>
  </div>
</div>
