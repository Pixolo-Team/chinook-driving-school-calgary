---
import { isMenuItemActive } from "@/data/menu";

interface MenuItemData {
  name: string;
  url: string;
}

interface Props {
  items: MenuItemData[];
  variant?: "primary" | "floating";
}

const { items, variant = "primary" } = Astro.props as Props;
const currentPath = Astro.url.pathname;
const isHome = currentPath === "/" || currentPath === "/index.html" || currentPath === "";
// Keep the enrollment route as a dedicated CTA so the primary nav stays focused on page links.
const navItems = items.filter((item) => item.url !== "/enroll");

const navClassName =
  variant === "primary"
    ? "flex items-center gap-5 text-sm leading-5 lg:gap-7"
    : "flex items-center gap-5 text-sm leading-5 lg:gap-7";
const navLabel = variant === "primary" ? "Primary" : "Floating navigation";
---

<nav aria-label={navLabel} class={navClassName}>
  {
    navItems.map((item) => {
      const isActiveLink = isMenuItemActive(currentPath, item.url);
      const linkClasses =
        variant === "primary"
          ? [
              "dynamic-menu-link",
              isActiveLink ? "font-semibold" : "font-medium",
              isHome
                ? "text-white hover:text-white/80"
                : "text-n-950 hover:text-n-800 dark:text-white dark:hover:text-white/80",
            ]
          : [
              isActiveLink ? "font-semibold" : "font-medium",
              "text-n-950 hover:text-n-800 dark:text-white dark:hover:text-white/80",
            ];
      const indicatorClasses =
        variant === "primary"
          ? "bg-current -bottom-3 h-0.5 w-full"
          : "inset-x-0 -bottom-4 h-1 w-full bg-blue-500 lg:-bottom-6";

      return (
        <a
          href={item.url}
          aria-current={isActiveLink ? "page" : undefined}
          class:list={[
            "group text-xs leading-5 whitespace-nowrap transition-colors duration-200 lg:text-sm",
            "focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 rounded-sm",
            linkClasses,
          ]}
        >
          <span class:list={["relative inline-flex", variant === "floating" && "px-1 lg:px-1.5"]}>
            <span>{item.name}</span>

            <span
              class:list={[
                "absolute left-1/2 -translate-x-1/2 rounded-lg transition-all duration-200 ease-out",
                isActiveLink
                  ? "scale-x-100 opacity-100"
                  : "scale-x-0 opacity-0 group-hover:scale-x-100 group-hover:opacity-100 group-focus-visible:scale-x-100 group-focus-visible:opacity-100",
                indicatorClasses,
              ]}
            />
          </span>
        </a>
      );
    })
  }
</nav>
