---
import { Icon } from "astro-icon/components";

interface Props {
  icon: string;
  stat_number: string;
  stat_suffix?: string;
  description: string;
}

const { icon, stat_number, stat_suffix = "", description } = Astro.props as Props;
---

<div
  data-stat-card
  class="border-n-200 bg-n-50 flex h-full flex-col items-center justify-center gap-2 rounded-4xl border px-8 pt-5 pb-7 text-center lg:pt-6 lg:pb-8"
  style="opacity: 0; transform: translateY(28px);"
>
  <!-- Icon -->
  <div class="rounded-full bg-blue-50 p-3">
    <Icon name={icon} class="size-9.5 text-blue-500" aria-hidden="true" />
  </div>

  <!-- Text -->
  <div class="flex flex-col items-center gap-1">
    <p class="text-3xl font-bold text-blue-500 lg:text-5xl [font-variant-numeric:tabular-nums]">
      <span data-stat-counter data-target={stat_number}>
        {stat_number}
      </span><span>{stat_suffix}</span>
    </p>
    <p class="text-n-700 text-sm font-semibold text-pretty lg:text-base">
      {description}
    </p>
  </div>
</div>

<script>
  import { animate, inView } from "motion";
  import { animateAxisFade, prefersReducedMotion, revealElementImmediately, wait } from "@/scripts/motion";

  const statCards = [...document.querySelectorAll("[data-stat-card]")].filter(
    (card): card is HTMLElement => card instanceof HTMLElement,
  );
  const statsGrid = document.querySelector("[data-stats-grid]");
  const animationDuration = 1.8;
  const staggerDelayMs = 110;
  const counterStartDelayMs = 120;
  const cardAnimationDuration = 0.68;
  const inViewStartDelayMs = 280;

  const formatCounterValue = (value: number, decimals: number) => {
    if (decimals > 0) {
      return value.toFixed(decimals);
    }

    return Math.round(value).toString();
  };

  const animateCardCounter = (card: HTMLElement) => {
    const counter = card.querySelector("[data-stat-counter]");

    if (!(counter instanceof HTMLElement)) {
      return Promise.resolve();
    }

    const targetValue = Number.parseFloat(counter.dataset.target ?? "");

    if (!Number.isFinite(targetValue)) {
      return Promise.resolve();
    }

    const decimalPart = counter.dataset.target?.split(".")[1] ?? "";
    const decimalPlaces = decimalPart.length;
    const updateCounter = (latest: number) => {
      counter.textContent = formatCounterValue(latest, decimalPlaces);
    };

    if (prefersReducedMotion()) {
      updateCounter(targetValue);
      return Promise.resolve();
    }

    const animation = animate(0, targetValue, {
      duration: animationDuration,
      ease: [0.22, 1, 0.36, 1],
      onUpdate: (latest) => {
        updateCounter(latest);
      },
    });

    return animation.then(() => {
      updateCounter(targetValue);
    });
  };

  const animateCardEntrance = (card: HTMLElement) => {
    return animateAxisFade(card, {
      axis: "y",
      from: 28,
      duration: cardAnimationDuration,
    });
  };

  statCards.forEach((card) => {
    if (card.dataset.statInitialized === "true") {
      return;
    }

    card.dataset.statInitialized = "true";
    const counter = card.querySelector("[data-stat-counter]");

    if (prefersReducedMotion()) {
      revealElementImmediately(card, "y");
    }

    if (counter instanceof HTMLElement) {
      counter.textContent = "0";
    }
  });

  if (statCards.length > 0 && statsGrid instanceof HTMLElement) {
    const stopWatching = inView(
      statsGrid,
      () => {
        if (document.body.dataset.statsSequenceStarted === "true") {
          stopWatching();
          return;
        }

        document.body.dataset.statsSequenceStarted = "true";

        void (async () => {
          if (!prefersReducedMotion()) {
            await wait(inViewStartDelayMs);
          }

          statCards.forEach((card, index) => {
            void (async () => {
              if (index > 0) {
                await wait(index * staggerDelayMs);
              }

              const entranceAnimation = animateCardEntrance(card);

              if (!prefersReducedMotion()) {
                await wait(counterStartDelayMs);
              }

              await Promise.all([entranceAnimation, animateCardCounter(card)]);
            })();
          });
        })();

        stopWatching();
      },
      { margin: "0px 0px -6% 0px" },
    );
  }
</script>
