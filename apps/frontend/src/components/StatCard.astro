---
import { Icon } from "astro-icon/components";

interface Props {
  icon: string;
  value: string;
  label: string;
}

const { icon, value, label } = Astro.props as Props;
---

<div
  class="border-n-200 bg-n-50 flex h-full flex-col items-center justify-center gap-2 rounded-4xl border px-8 pt-5 pb-7 text-center lg:pt-6 lg:pb-8"
>
  <!-- Icon -->
  <div class="rounded-full bg-blue-50 p-3">
    <Icon name={icon} class="size-9.5 text-blue-500" aria-hidden="true" />
  </div>

  <!-- Text -->
  <div class="flex flex-col items-center gap-1">
    <p class="text-3xl font-bold text-blue-500 lg:text-5xl">
      {value}
    </p>
    <p class="text-n-700 text-sm font-semibold text-nowrap lg:text-base">
      {label}
    </p>
  </div>
</div>
