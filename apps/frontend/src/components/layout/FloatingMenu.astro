---
// COMPONENTS //
import Button from "@/components/ui/Button.astro";
import MenuBar from "@/components/MenuBar.astro";
import BrandLogo from "@/components/common/BrandLogo.astro"; 

// CONSTANTS //
import { URLS } from "@/infrastructure/constants/urls";


// DATA //
import { menuItems } from "@/data/menu";

---

<!-- FloatingMenu -->
<div
  id="floating-menu-shell"
  class="fixed inset-x-0 top-3 z-50 hidden lg:block"
  aria-hidden="true"
  inert
>
  <div class="mx-auto w-full max-w-screen-2xl px-4 lg:px-5">
    <div
      id="floating-menu"
      class="outline-n-300 bg-n-50 pointer-events-none mx-auto flex w-full max-w-248.5 items-center overflow-hidden rounded-full px-4 py-2 opacity-0 shadow-lg outline-2 lg:px-5 lg:py-2.5 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
    >
      <div class="flex w-full items-center justify-between">
        <!-- Brand Logo -->
        <a href="/" aria-label="Chinook Driving Academy home" class="shrink-0">
          <BrandLogo
            containerClass="inline-flex h-12 items-center gap-0.5"
            markClass="h-full w-auto shrink-0 object-contain"
            textClass="h-7 w-auto shrink-0 object-contain"
            textAlt="Chinook Driving Academy"
          />
        </a>

        <div class="flex items-center gap-8 lg:gap-11">
          <!-- Navigation Menu -->
          <MenuBar variant="floating" items={menuItems} />

          <!-- Menu Button Group -->
          <div class="flex items-center gap-2 lg:gap-2.5">
            <Button buttonText="Enroll Now" className="w-26.5" href={URLS.ENROLL} />
            <Button
              buttonText="Call Us"
              rightIcon="phone-icon"
              variant="outline"
              href={URLS.CONTACT}
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
