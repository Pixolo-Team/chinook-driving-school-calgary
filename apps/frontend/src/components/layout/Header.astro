---
import { Icon } from "astro-icon/components";
import Button from "@/components/ui/Button.astro";
import FloatingMenu from "@/components/layout/FloatingMenu.astro";
import MobileMenu from "@/components/layout/MobileMenu.astro";
import MenuBar from "@/components/MenuBar.astro";
import BrandLogo from "@/components/common/BrandLogo.astro";
import { URLS } from "@/infrastructure/constants/urls";

// DATA //
import { menuItems } from "@/data/menu";

const currentPath = Astro.url.pathname;
const isHome = currentPath === "/" || currentPath === "/index.html" || currentPath === "";
const logoWordmarkColorClass = isHome ? "text-white" : undefined;
const enrollButtonClassName = [isHome ? "w-26.75 text-white" : "w-26.75"].join(" ");
const callUsButtonClassName = [
  "dynamic-call-btn flex items-center justify-center gap-2 pl-5 pr-3 transition-colors duration-300",
  isHome
    ? "border-white text-white hover:bg-white/10"
    : "border-n-900 text-n-900 hover:bg-n-900/10",
].join(" ");
---

<!-- Keep the mobile header in the main header component so breakpoint-specific chrome lives in one place. -->
<header
  id="mobile-header-shell"
  class="fixed inset-x-0 top-0 z-40 flex items-center justify-between px-6 py-4 transition-[background-color,border-radius] duration-300 lg:hidden"
>
  <a
    id="mobile-header-logo"
    href="/"
    aria-label="Chinook Driving Academy home"
    class="shrink-0"
  >
    <BrandLogo
      containerClass="inline-flex h-14 items-center gap-0.5"
      markClass="h-full w-auto shrink-0 object-contain"
      textClass="h-8 w-auto shrink-0 object-contain"
      textAlt="Chinook Driving Academy"
      wordmarkColorClass="[color:var(--mobile-header-logo-color,var(--color-brand-logo-wordmark))]"
    />
  </a>

  <button
    id="mobile-menu-open-button"
    type="button"
    class="animate-bouncy-hover border-n-100 inline-flex size-10 items-center justify-center rounded-full border bg-transparent transition-colors duration-300"
    aria-controls="mobile-menu-panel"
    aria-expanded="false"
    aria-label="Open mobile menu"
  >
    <Icon id="mobile-menu-open-icon" name="menu-open" class="text-n-100 size-6 transition-colors duration-300" />
  </button>
</header>

<MobileMenu />

<!-- Menu component -->
<header
  class="relative hidden w-full lg:block"
>
  <div class="container mx-auto flex w-full items-center justify-between px-4 py-3 lg:px-5 lg:py-4">
    
    <!-- Brand Header Logo -->
    <a href="/" aria-label="Chinook Driving Academy home" class="shrink-0">
      <BrandLogo
        containerClass="inline-flex h-14 items-center gap-0.5"
        markClass="h-full w-auto shrink-0 object-contain"
        textClass="h-8 w-auto shrink-0 object-contain"
        textAlt="Chinook Driving Academy"
        wordmarkColorClass={logoWordmarkColorClass}
      />
    </a>

    <div class="flex items-center gap-8 lg:gap-11">
      <!-- Menu links -->
      <MenuBar items={menuItems} />

      <!-- Menu CTAs -->
      <div class="flex items-center gap-2 lg:gap-2.5">
        <!-- Enroll Now Button -->
        <Button buttonText="Enroll Now" className={enrollButtonClassName} href={URLS.ENROLL} />

        <!-- Contact Us Button -->
        <Button
          buttonText="Call Us"
          rightIcon="phone-icon"
          variant="outline"
          className={callUsButtonClassName}
          href={URLS.PHONE}
        />
      </div>
    </div>
  </div>
</header>

<FloatingMenu />

<script>
  import { initializeFloatingMenu, initializeMobileHeader } from "@/scripts/menu";

  // Keep the mobile header readable over changing sections while preserving its fixed layout.
  initializeMobileHeader({
    scrollThreshold: 24,
  });

  // Delay the floating header until the hero has started to clear the viewport.
  initializeFloatingMenu({
    menuId: "floating-menu",
    scrollThreshold: 180,
  });

  function applyHeaderTheme() {
    // Check if the current URL is exactly the root (localhost:4321 or yourdomain.com/)
    const path = window.location.pathname;
    const isHome = path === "/" || path === "/index.html" || path === "";

    // 1. Update the Mobile Hamburger Icon
    const mobileIcon = document.getElementById("mobile-menu-open-icon");
    const mobileBtn = document.getElementById("mobile-menu-open-button");
    
    if (mobileIcon && mobileBtn) {
      if (isHome) {
        mobileIcon.classList.remove("text-n-900");
        mobileIcon.classList.add("text-n-100"); // White theme
        mobileBtn.classList.remove("border-n-900");
        mobileBtn.classList.add("border-n-100");
      } else {
        mobileIcon.classList.remove("text-n-100");
        mobileIcon.classList.add("text-n-900"); // Black theme
        mobileBtn.classList.remove("border-n-100");
        mobileBtn.classList.add("border-n-900");
      }
    }

    // 2. Update the "Call Us" Button
    const callUsButtons = document.querySelectorAll('.dynamic-call-btn');

    callUsButtons.forEach((callUsBtn) => {
      if (isHome) {
        // Apply White Theme
        callUsBtn.classList.remove("border-n-900", "text-n-900", "hover:bg-n-900/10");
        callUsBtn.classList.add("border-white", "text-white", "hover:bg-white/10");
      } else {
        // Apply Black Theme
        callUsBtn.classList.remove("border-white", "text-white", "hover:bg-white/10");
        callUsBtn.classList.add("border-n-900", "text-n-900", "hover:bg-n-900/10");
      }
    });
  }

  // Run the theme check on standard load
  document.addEventListener("DOMContentLoaded", applyHeaderTheme);
  
  // Run the theme check if Astro swaps pages using ViewTransitions
  document.addEventListener("astro:page-load", applyHeaderTheme);
</script>
