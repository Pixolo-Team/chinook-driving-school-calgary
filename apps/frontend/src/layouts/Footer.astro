---
// DATA //
import { footerSectionData } from "@/data/footer-section-data";

// COMPONENTS //
import { Image } from "astro:assets";
---

<section class="bg-n-50">
  <div class="container mx-auto w-full max-w-screen-2xl px-4 py-9 sm:px-6 sm:py-10 md:px-7 lg:px-8 lg:py-12 xl:px-10">

    <!-- Chinook Logo & Links  -->
    <div class="relative flex flex-col gap-9 md:gap-10 lg:flex-row lg:items-start lg:justify-between">
      <div class="flex w-full flex-col gap-3.5 lg:w-64">

        <!-- Chinook Logo -->
        <div
          class="relative h-14 w-36 lg:h-20 lg:w-52"
          role="img"
          aria-label={footerSectionData.logo.alt}
        >
          <Image
            src={footerSectionData.logo.mark}
            alt=""
            width={65}
            height={82}
            class="absolute left-0 top-0 h-full w-12 object-contain lg:w-16"
            loading="lazy"
            aria-hidden="true"
          />
          <Image
            src={footerSectionData.logo.text}
            alt={footerSectionData.logo.alt}
            width={144}
            height={42}
            class="absolute left-11 top-1/2 h-8 w-28 -translate-y-1/2 object-contain lg:left-16 lg:h-10 lg:w-36"
            loading="lazy"
          />
        </div>

        <!-- Certified by Alberta Transportation -->
        <p class="text-n-600 text-xs lg:text-sm">
          {footerSectionData.certification.prefix}
          <span class="font-semibold">{footerSectionData.certification.emphasis}</span>
        </p>
      </div>

      <!-- Nav Links -->
      <div class="flex flex-col gap-6 lg:absolute lg:left-1/2 lg:top-6 lg:-translate-x-1/2 lg:items-center">
        <div class="flex flex-col gap-2.5 text-sm text-n-600 md:text-base lg:flex-row lg:gap-10">
          {
            footerSectionData.navLinks.map((link) => (
              <a href={link.href} class="leading-6">
                {link.label}
              </a>
            ))
          }
        </div>

        <div class="flex items-center gap-3">
          {
            footerSectionData.socialLinks.map((link) => (
              <div class="size-11">
                <Image
                  src={link.icon}
                  alt={link.label}
                  width={44}
                  height={44}
                  class="size-full"
                  loading="lazy"
                />
              </div>
            ))
          }
        </div>
      </div>

      <!-- Privacy Policy & T&C Links -->
      <div class="flex flex-col gap-3 text-sm text-n-600 md:text-base lg:items-end">
        {
          footerSectionData.legalLinks.map((link) => (
            <a href={link.href} class="leading-4">
              {link.label}
            </a>
          ))
        }
      </div>
    </div>


    <!-- Copyright & Crafter by Pixolo -->
    <div class="mt-9 border-t border-n-200 pt-5 lg:mt-12">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
        <p class="text-n-400 text-sm">{footerSectionData.copyright}</p>

        <div class="flex flex-col gap-1 lg:items-center">
          <p class="text-n-700 text-sm">{footerSectionData.craftedBy.label}</p>
          <div class="h-9 w-32">
            <Image
              src={footerSectionData.craftedBy.logo}
              alt={footerSectionData.craftedBy.alt}
              width={144}
              height={41}
              class="size-full object-contain"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
