---
import { Image } from "astro:assets";

const heroImage = "https://www.figma.com/api/mcp/asset/a43dd646-5d1f-4e3c-a550-47d7a2c37f44";
---

<section class="relative w-full h-[100dvh] max-h-[945px] overflow-hidden bg-n-900 flex flex-col justify-end">
  <div class="absolute inset-0">
    <Image
      src={heroImage}
      alt=""
      width={1920}
      height={945}
      class="h-full w-full object-cover object-[60%_top] lg:object-top"
      aria-hidden="true"
    />
  </div>

  <div class="absolute inset-x-0 bottom-0 h-[70%] max-h-[600px] bg-gradient-to-t from-n-900/90 via-n-900/60 to-transparent"></div>

  <div class="relative pb-12 sm:pb-16 lg:pb-20 z-10 w-full">
    <div class="container mx-auto w-full max-w-screen-2xl px-5 lg:px-0">
      <div class="flex max-w-3xl flex-col gap-1.5 text-n-50">
        <p class="text-3xl uppercase tracking-wide">
          WE LOVE TEACHING
        </p>
        <p class="text-3xl font-semibold leading-tight sm:text-4xl lg:text-5xl">
          Proper guidance leads to Safer roads for our families.
        </p>
      </div>
    </div>
  </div>
</section>
