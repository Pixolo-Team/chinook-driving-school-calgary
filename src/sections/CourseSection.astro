---
// COMPONENTS //
import CourseCard from "@/components/CourseCard.astro";

// DATA //
import { courseSectionData } from "@/data/course-section-data";

// Keep the initial tab selection deterministic between the server render and browser hydration.
const activeTabIndex = 0;
---

<section>
  <div
    class="container mx-auto flex w-full max-w-screen-2xl flex-col items-center gap-10 px-6 py-20 lg:gap-16 lg:px-12 lg:py-28"
  >
    <!-- Section Header -->
    <div class="flex w-full max-w-2xl flex-col items-center gap-2 text-center">
      <!-- Section Head -->
      <p class="text-sm font-bold tracking-[0.6px] text-blue-500 uppercase">
        {courseSectionData.eyebrow}
      </p>

      <!-- Section Title -->
      <p class="text-n-800 text-3xl leading-tight font-bold sm:text-4xl lg:text-5xl">
        {courseSectionData.heading}
      </p>

      <!-- Title Description -->
      <p class="text-n-600 text-sm leading-relaxed sm:text-base">
        {courseSectionData.description}
      </p>
    </div>

    <div
      class="flex w-full flex-col gap-7"
      data-course-section
      data-active-tab-index={activeTabIndex}
    >
      <div class="flex w-full items-center gap-3.5">
        {
          courseSectionData.tabs.map((tab, index) => (
            <button
              type="button"
              data-course-tab
              data-tab-index={index}
              aria-pressed={index === activeTabIndex ? "true" : "false"}
              class:list={[
                "relative flex w-full items-center justify-center py-2.5 text-center text-xs font-semibold text-nowrap sm:py-3 sm:text-sm",
                "after:absolute after:bottom-0 after:left-0 after:w-full after:content-[''] after:transition-all after:duration-200",
                index === activeTabIndex
                  ? "text-blue-500 after:h-[2px] after:bg-blue-500"
                  : "text-n-600 after:h-px after:bg-n-200",
              ]}
            >
              {tab.label}
            </button>
          ))
        }
      </div>

      {
        courseSectionData.tabs.map((tab, index) => (
          <div
            data-course-panel
            data-panel-index={index}
            class:list={[
              "grid w-full grid-cols-1 gap-5 lg:grid-cols-3 lg:gap-5 lg:divide-x-0",
              index === activeTabIndex ? "grid" : "hidden",
            ]}
          >
            {tab.cards.map((courseCardItem) => <CourseCard card={courseCardItem} />)}
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const courseSection = document.querySelector<HTMLElement>("[data-course-section]");
  const courseTabs = courseSection?.querySelectorAll<HTMLButtonElement>("[data-course-tab]") ?? [];

  let activeTabIndex = 0;

  // Astro renders the initial tab markup statically, so the browser needs to re-apply the active styles after clicks.
  const updateActiveTab = () => {
    const coursePanels = courseSection?.querySelectorAll<HTMLElement>("[data-course-panel]") ?? [];

    courseTabs.forEach((tab) => {
      const tabIndex = Number(tab.dataset.tabIndex ?? "0");
      const isActive = tabIndex === activeTabIndex;

      tab.setAttribute("aria-pressed", String(isActive));
      tab.classList.toggle("text-blue-500", isActive);
      tab.classList.toggle("text-n-600", !isActive);
      tab.classList.toggle("after:bg-blue-500", isActive);
      tab.classList.toggle("after:h-[2px]", isActive);
      tab.classList.toggle("after:bg-n-200", !isActive);
      tab.classList.toggle("after:h-px", !isActive);
    });

    coursePanels.forEach((panel) => {
      const panelIndex = Number(panel.dataset.panelIndex ?? "0");
      const isActive = panelIndex === activeTabIndex;

      panel.classList.toggle("grid", isActive);
      panel.classList.toggle("hidden", !isActive);
    });

    if (courseSection) {
      courseSection.dataset.activeTabIndex = String(activeTabIndex);
    }
  };

  courseTabs.forEach((tab) => {
    // Preserve the selected index in one place so future tab-specific card filtering can reuse the same state.
    tab.addEventListener("click", () => {
      const nextTabIndex = Number(tab.dataset.tabIndex ?? "0");

      activeTabIndex = nextTabIndex;
      updateActiveTab();
    });
  });

  updateActiveTab();
</script>
