---
// COMPONENTS //
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

// IMAGES //
import chinookLogo from "@/../public/images/chinook-logo.png";

const menuLinks = [
  { label: "Home", href: "#home", isActive: true },
  { label: "About Us", href: "#about", isActive: false },
  { label: "Courses", href: "#courses", isActive: false },
  { label: "Contact Us", href: "#contact", isActive: false },
];
---

<section class="py-6">
  <div class="container mx-auto px-4 sm:px-6 lg:px-0">
    <div class="flex w-full flex-col items-center gap-4 rounded-4xl border-2 border-n-300 bg-n-50 px-5 py-2.5 shadow-lg lg:flex-row lg:justify-between lg:gap-10">
      <a href="/" class="flex items-center">
        <Image
          src={chinookLogo}
          alt="Chinook Driving Academy logo"
          class="h-11 w-auto"
          loading="eager"
          referrerpolicy="no-referrer"
          width={117}
          height={46}
        />
      </a>

      <div class="flex w-full flex-col items-center gap-4 lg:w-auto lg:flex-row lg:gap-11">
        <nav class="w-full lg:w-auto" aria-label="Primary">
          <ul class="flex flex-wrap items-center justify-center gap-6 text-sm font-medium text-n-800">
            {menuLinks.map((link) => (
              <li class="flex flex-col items-center">
                <a
                  href={link.href}
                  aria-current={link.isActive ? "page" : undefined}
                  class:list={[
                    "transition-colors duration-200",
                    link.isActive ? "font-semibold text-blue-500" : "text-n-800",
                  ]}
                >
                  {link.label}
                </a>
                {link.isActive && (
                  <span class="mt-2 h-1 w-16 rounded-lg bg-blue-500"></span>
                )}
              </li>
            ))}
          </ul>
        </nav>

        <div class="flex flex-wrap items-center justify-center gap-2.5">
          <a
            href="#enroll"
            class="inline-flex h-10 items-center justify-center rounded-3xl bg-blue-500 px-4 text-sm font-semibold text-n-50 transition-colors duration-200 hover:bg-blue-600"
          >
            Enroll Now
          </a>
          <a
            href="#contact"
            class="inline-flex h-10 items-center justify-center gap-2 rounded-3xl border-2 border-blue-500 px-4 text-sm font-semibold text-blue-500 transition-colors duration-200 hover:bg-blue-50"
          >
            Call Us
            <Icon name="phone" class="size-4" aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
