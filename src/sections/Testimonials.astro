---
// COMPONENTS //
import TestimonialCard from "@/components/TestimonialCard.astro";

// DATA //
import { testimonialSectionDetails } from "@/data/testimonials";
import type { TestimonialData } from "@/types/testimonial";
import { Icon } from "astro-icon/components";

const { testimonials } = testimonialSectionDetails;
---

<!-- ============================================================
     review-section
     Flow      : Vertical
     Width     : Fill  → w-full
     Max-width : container/2xl → max-w-screen-2xl
     Padding   : top/bottom space/32 → pt-8 pb-8
                 left/right space/40 → pl-10 pr-10
     Gap       : space/16 → gap-4
============================================================ -->
<section class="review-section w-full">

  <!-- container -->
  <div class="container mx-auto px-6 py-11 flex flex-col gap-7 lg:px-40 lg:py-32 lg:gap-16">

    <!-- ── header ─────────────────────────────────────────── -->
    <div class="header flex flex-col items-center gap-1">

      <!-- "Google Reviews" label -->
      <p class="font-poppins font-bold text-xs leading-4 tracking-normal text-center uppercase align-center lg:text-sm text-blue-500">
        Google Reviews
      </p>

      <!-- Heading -->
      <h2 class="font-poppins font-bold text-3xl leading-tight tracking-normal text-center lg:text-5xl">
        Trusted by 100s of Calgary Learners
      </h2>

    </div>
   

    <!-- ── content-wrap ───────────────────────────────────── -->
    <div class="flex flex-col gap-5 lg:gap-12">

      <!-- ── review-rating ──────────────────────────────── -->
      <div class="review-rating flex flex-col gap-2.5 lg:justify-between lg:flex-row ">

        <!-- Left: label + stars + count -->
        <div class="flex flex-col gap-0.5 lg:gap-4 self-start ">
          <div class="font-inter font-medium text-lg leading-tight tracking-normal">
            Customer reviews on Google
          </div>

          <div class="flex items-center gap-1">
            <!-- Stars -->
           <div class="flex items-center gap-1" aria-label="5 out of 5 stars">
              {Array.from({ length: 5 }, (_, index) => (
                <Icon
                  name="star"
                  class:list={[
                    "size-4",
                    index < 5 ? "text-yellow-500" : "text-n-300",
                  ]}
                  aria-hidden="true"
                />
              ))}
            </div>

            <span class="font-inter font-medium text-xs leading-tight tracking-normal text-center">
              5.0 rating of 12 reviews
            </span>
          </div>
        </div>

        <!-- Right: CTA button -->
        <button
          class="font-inter w-fit py-2 px-4 rounded-lg opacity-100 lg:py-4 lg:px-6 lg:gap-2.5 bg-blue-500 text-n-100 text-xs text-medium leading-tight tracking-normal text-center lg:text-base lg:leading-5"
        >
          Leave a Review  
        </button>

      </div>
      <!-- /review-rating -->

      <!-- ── cards-wrap ─────────────────────────────────── -->
      <div class="cards-wrap flex flex-col gap-4 relative">
 
        <!-- Scrollable track -->
        <div
          id="testimonial-track"
          class="flex gap-4 overflow-x-auto snap-x snap-mandatory scrollbar-hide lg:overflow-x-visible lg:grid lg:grid-cols-3"
        >
          {testimonials.map((testimonial) => (
            <div class="flex-shrink-0 w-full snap-start lg:w-auto">
              <TestimonialCard
                testimonial={testimonial}
                rating={testimonial.rating}
              />
            </div>
          ))}
        </div>
 
        <!-- Mobile prev/next buttons — hidden on lg and above -->
        <div class="flex items-center justify-end gap-3 lg:hidden">
 
          <!-- Prev button -->
          <button
            id="testimonial-prev"
            class="w-10 h-10 rounded-full bg-white shadow-md
                   flex items-center justify-center
                   hover:bg-gray-50 transition-colors duration-150"
            aria-label="Previous review"
          >
            <svg
              class="w-4 h-4 text-gray-600"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>

 
          <!-- Next button -->
          <button
            id="testimonial-next"
            class="w-10 h-10 rounded-full bg-white shadow-md
                   flex items-center justify-center
                   hover:bg-gray-50 transition-colors duration-150"
            aria-label="Next review"
          >
            <svg
              class="w-4 h-4 text-gray-600"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </button>
          <button
              id="testimonial-next-desktop"
              class="absolute -right-5 top-1/2 -translate-y-1/2
                     w-10 h-10 rounded-full bg-white shadow-md
                     items-center justify-center
                     hover:bg-gray-50 transition-colors duration-150
                     flex max-lg:hidden"
              aria-label="Next review"
            >
              <svg
                class="w-4 h-4 text-gray-600"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
          </button>
 
        </div>
        <!-- /mobile buttons -->
 
      </div>
      <!-- /cards-wrap -->

      <!-- /cards-wrap -->

    </div>
    <!-- /content-wrap -->

  </div>
  <!-- /container -->

</section>
<!-- /review-section -->