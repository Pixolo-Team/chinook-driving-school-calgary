---
// COMPONENTS //
import TestimonialCard from "@/components/TestimonialCard.astro";
// DATA //
import { testimonialSectionDetails } from "@/data/testimonials";
---

<section class="bg-white w-full">
  <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 py-10 sm:py-16 lg:py-24">

    <div class="flex flex-col items-center text-center mb-10 lg:mb-16">
      
      <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-blue-600 mb-4">
        Google Reviews
      </span>

      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-[#1a202c] leading-[1.15] max-w-4xl">
        Trusted by 100s of Calgary Learners
      </h2>

      <div class="flex flex-col w-full sm:flex-row justify-between gap-10 sm:gap-8 mt-10">
        
        <div class="flex flex-col items-center sm:items-start">
          <p class="text-[13px] text-gray-900 font-bold mb-1">Customer reviews on Google</p>
          <div class="flex  gap-1.5">
            <div class="flex items-center gap-0.5" aria-label="5 star rating">
              {Array.from({ length: 5 }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-yellow-400">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-[13px] text-gray-600 font-medium">5.0 rating of {testimonialSectionDetails.testimonials.length} reviews</span>
          </div>
        </div>

        <a
          href="https://g.page/r/review"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2.5  rounded-md bg-[#2573d9] hover:bg-blue-700 text-white text-sm font-bold transition-all shadow-sm"
        >
          Leave a Review
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {
        testimonialSectionDetails.testimonials.map((testimonial) => (
          <div class="w-full">
            <TestimonialCard
              testimonial={testimonial}
              rating={testimonial.rating}
            />
          </div>
        ))
      }
    </div>

  </div>
</section>