---
// COMPONENTS //
import { Image } from "astro:assets";

const { cardItem } = Astro.props;
---
<div class="w-[312px] overflow-hidden rounded-4xl border-2 border-n-100 pb-11 transform transition duration-300 ease-in-out hover:scale-105">
  <div class="flex h-full flex-col gap-6">
    <div class="relative h-[171px] w-auto">
      <Image
        alt={cardItem.imageAlt}
        class="absolute left-0 top-[-6.73%] h-[117.04%] w-full max-w-none"
        height={200}
        src={cardItem.imageSrc}
        width={180}
      />
    </div>
    <div class="flex flex-col gap-3.5 px-6">
      <h3 class="text-2xl font-bold leading-[1.2] text-n-800">
        {cardItem.title}
      </h3>
      <p class="text-sm font-medium text-n-500">
        {cardItem.description}
      </p>
    </div>
  </div>
</div>