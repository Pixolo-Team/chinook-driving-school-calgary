---
// COMPONENTS //
import { Image } from "astro:assets";
import Button from "@/components/ui/Button.astro";
import FloatingMenu from "@/components/FloatingMenu.astro";
import MenuBar from "@/components/MenuBar.astro";

// CONSTANTS //
import { URLS } from "@/infrastructure/constants/urls";

// DATA //
import { menuItems } from "@/data/menu";

// IMAGES //
import menuLogo from "@/assets/menu-logo.png";
---

<!-- Menu component -->
<header
  class="relative hidden w-full bg-linear-to-b from-[#1E293BC4] via-[#1E293BA1] to-transparent sm:block"
>
  <div class="container mx-auto flex w-full items-center justify-between px-4 py-3 lg:px-5 lg:py-4">
    <!-- Brand Header Logo -->
    <a href="/" aria-label="Chinook Driving Academy home" class="w-30 shrink-0 lg:w-36">
      <Image src={menuLogo} alt="Chinook Driving Academy" width={146} height={58} class="w-full" />
    </a>

    <div class="flex items-center gap-8 lg:gap-11">
      <!-- Menu links -->
      <MenuBar items={menuItems} />

      <!-- Menu CTAs -->
      <div class="flex items-center gap-2 lg:gap-2.5">
        <!-- Enroll Now Button -->
        <Button buttonText="Enroll Now" className="w-26.75" href={URLS.ENROLL} />

        <!-- Contact Us Button -->
        <Button
          buttonText="Call Us"
          rightIcon="phone-icon"
          variant="outline"
          className="border-n-50 text-n-50 hover:bg-n-50/10"
          href={URLS.CONTACT}
        />
      </div>
    </div>
  </div>
</header>

<FloatingMenu />

<script>
  import { initializeFloatingMenu } from "@/scripts/menu";

  // Delay the floating header until the hero has started to clear the viewport.
  initializeFloatingMenu({
    menuId: "floating-menu",
    scrollThreshold: 180,
  });
</script>
