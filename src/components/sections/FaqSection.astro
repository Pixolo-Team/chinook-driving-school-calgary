---
// DATA
import { faqSectionData as faqs } from "@/data/faqSectionData";

---

<section>
  <div class="container mx-auto flex w-full flex-col items-center gap-16 overflow-hidden px-5 py-36 lg:px-0">

    <!-- Heading & Description -->
    <div class="flex flex-col items-center gap-2.5">
      <p class="text-sm font-bold uppercase tracking-[0.6px] text-blue-600">
        Got Questions ?
      </p>
      <p
        class="text-center text-3xl font-bold leading-[1.25] text-n-800 md:text-5xl lg:text-5xl"
      >
        Frequently Asked Questions
      </p>
    </div>

    <!-- FAQ Card Component -->
    <div class="flex w-full max-w-3xl mx-auto flex-col gap-4">

      <!-- Iterating through FAQs -->
      {faqs.map((faqItem, index) => (
        <div
          class="faq-item flex w-full flex-col overflow-hidden rounded-3xl border border-n-200  p-px">

          <button
            class="faq-trigger flex w-full items-center justify-between px-6 py-6 text-left">
            <p class="text-[18px] font-semibold leading-6 text-n-900">
              {faqItem.question}
            </p>
            {/* Dropdown Logo */}
            <img
              src="/icons/dropdown.svg"
              alt="toggle"
              class="faq-arrow h-[12px] w-3 shrink-0 transition-transform duration-300"
            />
          </button>
          <div
            class="faq-answer overflow-hidden transition-all duration-300"
            style="max-height: 0px; opacity: 0;">

              {/* FAQ Answer */}
            <div class="px-6 pb-5">
              <p class="text-[16px] leading-5 text-n-800">
                {faqItem.answer}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>

  // Select all FAQ items (each question-answer block)
  document.querySelectorAll<HTMLElement>(".faq-item").forEach((item) => {

    // Get elements inside each FAQ item
    const trigger = item.querySelector<HTMLButtonElement>(".faq-trigger"); // clickable question
    const answer = item.querySelector<HTMLElement>(".faq-answer"); // hidden answer section
    const arrow = item.querySelector<SVGElement>(".faq-arrow"); // arrow icon

    // Add click event to each FAQ trigger
    trigger?.addEventListener("click", () => {

      // Check if current FAQ is already open
      const isOpen = item.dataset.open === "true";

      if (isOpen) {
        item.dataset.open = "false"; 
        trigger.setAttribute("aria-expanded", "false"); 

        // Hide Content & Fade Out
        if (answer) {
          answer.style.maxHeight = "0px";
          answer.style.opacity = "0"; 
        }
        if (arrow) {
          (arrow as HTMLElement).style.transform = ""; 
        }
      } else {
        item.dataset.open = "true"; 
        trigger.setAttribute("aria-expanded", "true"); 

        // Show Content & Fade In
        if (answer) {
          answer.style.maxHeight = "500px"; 
          answer.style.opacity = "1"; 
        }

        if (arrow) {
          (arrow as HTMLElement).style.transform = "rotate(180deg)"; 
        }
      }
    });
  });
</script>