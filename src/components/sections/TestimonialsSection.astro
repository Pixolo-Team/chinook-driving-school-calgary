---
import { TestimonialSection } from "@/data/TestimonialsSection";
---

<section class="bg-n-900 py-10 sm:py-12 lg:py-16">
  <div class="mx-auto w-full max-w-[1200px] px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-10">
      {
        TestimonialSection.testimonials.map((testimonial:any) => (
          <div
            class:list={[
              "relative overflow-hidden rounded-4xl",
              "w-full max-w-[384px] justify-self-center",
              testimonial.customReview
                ? "bg-n-900"
                : "bg-n-900",
            ]}
          >
            {testimonial.customReview && (
              <div class="absolute -left-[99px] -top-[4px] h-[409px] w-[613px]">
                <img
                  alt="Profile photo"
                  class="absolute inset-0 size-full object-cover"
                  src={TestimonialSection.assets.imgShotOfAYoungBusinessmanWorkingOnAComputerInAnOffice1}
                />
              </div>
            )}
            <div
              class:list={[
                "relative z-10 flex flex-col items-start gap-5 overflow-hidden rounded-4xl px-6 pb-6 pt-36",
                testimonial.customReview
                  ? "bg-gradient-to-b from-transparent from-[8%] to-n-900"
                  : "bg-n-50",
              ]}
            >
              <div class="h-6 w-[136px]">
                <img alt="Profile photo" class="block size-full" src={TestimonialSection.assets.imgRatingWrap} />
              </div>
              <div class="w-full">
                <p
                  class:list={[
                    "text-base leading-tight",
                    testimonial.customReview
                      ? "text-n-50"
                      : "text-n-900",
                  ]}
                >
                  {testimonial.review}
                </p>
              </div>
              <div class="flex w-full items-center gap-2.5">
                <div class="flex flex-1 items-center gap-2.5">
                  <div
                    class:list={[
                      "size-10 overflow-hidden rounded-4xl border-2",
                      testimonial.customReview
                        ? "border-n-50"
                        : "border-n-900",
                    ]}
                  >
                    <img
                      alt="Profile"
                      class="size-full rounded-4xl object-cover"
                      src={TestimonialSection.assets.imgProfilePhoto}
                    />
                  </div>
                  <div
                    class:list={[
                      "flex flex-1 flex-col gap-0.5 leading-tight",
                      testimonial.customReview
                        ? "text-n-50"
                        : "text-n-900",
                    ]}
                  >
                    <p class="text-base font-semibold">{testimonial.name}</p>
                    <p class="text-xs">{testimonial.role}</p>
                  </div>
                </div>
                <div class="size-6">
                  <img alt="Profile photo" class="block size-full" src={TestimonialSection.assets.imgGoogleLogo} />
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
