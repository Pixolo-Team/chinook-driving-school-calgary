---
// STYLES //
import '../styles/global.css';
import '../styles/animation.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Chinook Driving School Calgary – new website coming soon." />
		<title>Coming Soon | Chinook Driving School Calgary</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet" />
	</head>
	<body class="min-h-screen bg-gradient-to-br from-blue-50 to-blue-100 flex items-center justify-center px-4">
		<main class="text-center max-w-lg w-full animate-fade-in">
			<!-- Logo / Icon -->
			<div class="flex justify-center mb-6">
				<div class="bg-blue-500 text-n-50 rounded-full w-24 h-24 flex items-center justify-center shadow-lg text-5xl">
					🚧
				</div>
			</div>

			<!-- Heading -->
			<h1 class="text-4xl sm:text-5xl font-bold text-blue-500 mb-4 leading-tight">
				We're Under Construction
			</h1>

			<!-- Subtext -->
			<p class="text-lg sm:text-xl text-n-600 mb-8">
				Our new website is coming soon. Stay tuned!
			</p>

			<!-- CTA Button -->
			<a
				href="https://www.chinookdrivingacademy.com/"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-block bg-blue-500 text-n-50 font-semibold px-6 py-3 rounded-lg shadow-md hover:bg-blue-600 transition-colors duration-200"
			>
				Visit Old Website
			</a>
		</main>
	</body>
</html>
